CONN_PORT=8080
# Listen on all interfaces so phones / port forwarding can reach the app
HOST=0.0.0.0
DB_URL=mongodb://127.0.0.1:27017/null-stay
SESSION_SECRET=change_me_in_production
# Use your PC's LAN IP when testing on phone (same Wi‑Fi), or your public URL when deployed
# Public site URL — used for SEO canonical links, Open Graph, and sitemap.xml (use HTTPS in production)
APP_URL=http://localhost:8080
SITE_NAME=NullStay

# In-memory cache (listing search, home featured, listing detail)
# CACHE_ENABLED=false
# CACHE_TTL_SECONDS=60
# CACHE_MAX_ENTRIES=300
# CACHE_DEBUG=true
# STATIC_CACHE_MAX_AGE=1d

# Developer-only routes (e.g. GET /dev/loc?key=... — min 16 characters)
# DEV_ACCESS_KEY=your_long_random_secret_here

RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_CURRENCY=INR
# For REAL payments use live keys from https://dashboard.razorpay.com/app/keys:
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=your_live_secret

# Web Push (real OS notifications — run: node utils_scripts/generate-vapid-keys.js)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=you@example.com

# Email (booking confirmations & cancellations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="NullStay" <your@gmail.com>
# Inbox for GET /contact form submissions (defaults to SMTP_USER)
SUPPORT_EMAIL=support@nullstay.com
