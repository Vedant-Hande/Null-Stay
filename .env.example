CONN_PORT=8080
DB_URL=mongodb://127.0.0.1:27017/null-stay
SESSION_SECRET=change_me_in_production
APP_URL=http://localhost:8080

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CURRENCY=inr
# For REAL payments, switch Stripe Dashboard to Live mode and use:
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# Enable UPI in Stripe Dashboard → Settings → Payment methods

# Web Push (real OS notifications — run: node utils_scripts/generate-vapid-keys.js)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=you@example.com

# Email (booking confirmations & cancellations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="NullStay" <your@gmail.com>
