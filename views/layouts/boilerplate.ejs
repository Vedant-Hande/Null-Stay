                                        <div
                                            class="bg-airbnb rounded-full text-white overflow-hidden w-7 h-7 flex items-center justify-center text-xs font-bold uppercase">
                                            <%= currentUser.username.charAt(0) %>
                                        </div>
                                        <% } else { %>
                                            <div
                                                class="bg-gray-500 rounded-full text-white overflow-hidden w-7 h-7 flex items-center justify-center">
                                                <i class="fa-solid fa-user text-xs"></i>
                                            </div>
                                            <% } %>
                                </div>

                                <!-- Dropdown Menu -->
                                <div id="userDropdown"
                                    class="absolute right-0 top-14 w-60 bg-white rounded-xl shadow-[0_8px_28px_rgba(0,0,0,0.15)] border border-gray-100 flex flex-col z-50 py-2 transition-all duration-200 transform origin-top-right opacity-0 scale-95 pointer-events-none">
                                    <% if (!currentUser) { %>
                                        <a href="/signup"
                                            class="px-4 py-3 hover:bg-gray-50 font-semibold text-sm transition">Sign
                                            up</a>
                                        <a href="/login" class="px-4 py-3 hover:bg-gray-50 text-sm transition">Log
                                            in</a>
                                        <div class="border-t border-gray-200 my-1"></div>
                                        <a href="#" class="px-4 py-3 hover:bg-gray-50 text-sm transition">Help
                                            Center</a>
                                        <% } else { %>
                                            <a href="/messages"
                                                class="px-4 py-3 hover:bg-gray-50 font-semibold text-sm transition">Messages</a>
                                            <a href="/notifications"
                                                class="px-4 py-3 hover:bg-gray-50 font-semibold text-sm transition flex items-center justify-between gap-2">
                                                <span>Notifications</span>
                                                <% if (unreadNotificationCount > 0) { %>
                                                    <span class="text-xs font-bold bg-airbnb text-white px-2 py-0.5 rounded-full"><%= unreadNotificationCount > 99 ? '99+' : unreadNotificationCount %></span>
                                                <% } %>
                                            </a>
                                            <a href="/bookings/trips"
                                                class="px-4 py-3 hover:bg-gray-50 font-semibold text-sm transition">Trips</a>
                                            <a href="/wishlists"
                                                class="px-4 py-3 hover:bg-gray-50 font-semibold text-sm transition">Wishlists</a>
                                            <div class="border-t border-gray-200 my-1"></div>
                                            <a href="/listings/new"
                                                class="px-4 py-3 hover:bg-gray-50 text-sm transition">Manage
                                                listings</a>
                                            <a href="/bookings/host"
                                                class="px-4 py-3 hover:bg-gray-50 text-sm transition">Reservations</a>
                                            <a href="/user/account"
                                                class="px-4 py-3 hover:bg-gray-50 text-sm transition">Account</a>
                                            <a href="/user/analytics"
                                                class="px-4 py-3 hover:bg-gray-50 text-sm transition">Analytics</a>
                                            <div class="border-t border-gray-200 my-1"></div>
                                            <a href="/logout" class="px-4 py-3 hover:bg-gray-50 text-sm transition">Log
                                                out</a>
                                            <% } %>
                                </div>
                            </div>
                </div>

            </div>
        </div>

        <!-- Categories Bar -->
        <% if (typeof isListingsPage !== "undefined" && isListingsPage) { %>
        <div class="max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4 py-2">
            <div class="flex flex-row items-center justify-between overflow-x-auto gap-8 pt-1 hide-scrollbar">
                <a href="/listings?category=pools"
                    class="flex flex-col items-center justify-center gap-1.5 pb-2 border-b-2 <%= searchQuery && searchQuery.category === 'pools' ? 'border-neutral-800 text-neutral-800 opacity-100' : 'border-transparent text-neutral-500 opacity-70' %> hover:border-neutral-300 hover:text-neutral-800 cursor-pointer min-w-max transition">
                    <i class="fa-solid fa-water text-lg"></i>
                    <div class="text-xs font-medium">Amazing pools</div>
                </a>
                <a href="/listings?category=beachfront"
                    class="flex flex-col items-center justify-center gap-1.5 pb-2 border-b-2 <%= searchQuery && searchQuery.category === 'beachfront' ? 'border-neutral-800 text-neutral-800 opacity-100' : 'border-transparent text-neutral-500 opacity-70' %> hover:border-neutral-300 hover:text-neutral-800 cursor-pointer min-w-max transition">
                    <i class="fa-solid fa-umbrella-beach text-lg"></i>
                    <div class="text-xs font-medium">Beachfront</div>
                </a>
                <a href="/listings?category=castles"
                    class="flex flex-col items-center justify-center gap-1.5 pb-2 border-b-2 <%= searchQuery && searchQuery.category === 'castles' ? 'border-neutral-800 text-neutral-800 opacity-100' : 'border-transparent text-neutral-500 opacity-70' %> hover:border-neutral-300 hover:text-neutral-800 cursor-pointer min-w-max transition">
                    <i class="fa-brands fa-fort-awesome text-lg"></i>
                    <div class="text-xs font-medium">Castles</div>
                </a>
                <a href="/listings?category=treehouses"
                    class="flex flex-col items-center justify-center gap-1.5 pb-2 border-b-2 <%= searchQuery && searchQuery.category === 'treehouses' ? 'border-neutral-800 text-neutral-800 opacity-100' : 'border-transparent text-neutral-500 opacity-70' %> hover:border-neutral-300 hover:text-neutral-800 cursor-pointer min-w-max transition">
                    <i class="fa-solid fa-tree text-lg"></i>
                    <div class="text-xs font-medium">Treehouses</div>
                </a>
                <a href="/listings?category=cabins"
                    class="flex flex-col items-center justify-center gap-1.5 pb-2 border-b-2 <%= searchQuery && searchQuery.category === 'cabins' ? 'border-neutral-800 text-neutral-800 opacity-100' : 'border-transparent text-neutral-500 opacity-70' %> hover:border-neutral-300 hover:text-neutral-800 cursor-pointer min-w-max transition">
                    <i class="fa-solid fa-house-user text-lg"></i>
                    <div class="text-xs font-medium">Cabins</div>
                </a>
                <a href="/listings?category=cities"
                    class="flex flex-col items-center justify-center gap-1.5 pb-2 border-b-2 <%= searchQuery && searchQuery.category === 'cities' ? 'border-neutral-800 text-neutral-800 opacity-100' : 'border-transparent text-neutral-500 opacity-70' %> hover:border-neutral-300 hover:text-neutral-800 cursor-pointer min-w-max transition">
                    <i class="fa-solid fa-city text-lg"></i>
                    <div class="text-xs font-medium">Iconic cities</div>
                </a>
            </div>
            <style>
                .hide-scrollbar::-webkit-scrollbar {
                    display: none;
                }

                .hide-scrollbar {
                    -ms-overflow-style: none;
                    scrollbar-width: none;
                }
            </style>
        </div>
        <% } %>
    </nav>
    </div>

    <!-- Main Content -->
    <main class="flex-grow w-full <%= typeof isHomePage !== 'undefined' && isHomePage ? 'p-0 max-w-none' : 'max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4 py-8' %>">
        <% if (typeof isHomePage === 'undefined' || !isHomePage) { %>
        <%- include("../includes/flash.ejs") %>
        <% } %>
        <%- body %>
    </main>
    <!-- Global confirm dialog (replaces browser confirm) -->
    <div id="nullstayConfirmModal" class="fixed inset-0 bg-neutral-900/40 backdrop-blur-sm z-[9998] hidden flex items-center justify-center p-4 select-none">
        <div class="bg-white rounded-3xl p-6 md:p-8 max-w-sm w-full shadow-2xl border border-gray-100 transform transition duration-300 scale-95 opacity-0" id="nullstayConfirmModalContent">
            <h3 id="nullstayConfirmTitle" class="text-xl font-semibold text-gray-900 tracking-tight">Are you sure?</h3>
            <p id="nullstayConfirmMessage" class="text-sm text-gray-500 font-normal mt-2 leading-relaxed"></p>
            <div class="flex items-center gap-3 mt-6">
                <button type="button" id="nullstayConfirmCancel" class="flex-1 py-3 text-sm font-bold text-gray-700 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-xl transition duration-200">
                    Cancel
                </button>
                <button type="button" id="nullstayConfirmOk" class="flex-1 py-3 text-sm font-bold text-white bg-gray-900 hover:bg-black rounded-xl shadow-md transition duration-200">
                    Confirm
                </button>
            </div>
        </div>
    </div>

    <!-- Beautiful Premium Delete Confirmation Modal -->
    <div id="deleteConfirmModal" class="fixed inset-0 bg-neutral-900/40 backdrop-blur-sm z-[9999] hidden flex items-center justify-center p-4 select-none">
        <div class="bg-white rounded-3xl p-6 md:p-8 max-w-sm w-full shadow-2xl border border-gray-100 transform transition duration-300 scale-95 opacity-0" id="deleteConfirmModalContent">
            <!-- Icon -->
            <div class="w-14 h-14 bg-rose-50 border border-rose-100 text-rose-600 rounded-2xl flex items-center justify-center text-xl mb-5 shadow-sm">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <!-- Title and Description -->
            <h3 class="text-xl font-bold text-gray-900 tracking-tight">Delete Listing</h3>
            <p class="text-xs text-gray-500 font-normal mt-1 leading-relaxed">
                Are you sure you want to permanently delete this property? This action cannot be undone.
            </p>
            <!-- Actions -->
            <div class="flex items-center gap-3 mt-6">
                <button type="button" onclick="closeDeleteModal()" class="flex-1 py-3 text-sm font-bold text-gray-700 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-xl transition duration-200">
                    Cancel
                </button>
                <button type="button" id="confirmDeleteBtn" class="flex-1 py-3 text-sm font-bold text-white bg-rose-600 hover:bg-rose-700 rounded-xl shadow-md hover:shadow-lg transition duration-200">
                    Delete
                </button>
            </div>
        </div>
    </div>

    <script>
        let formToSubmit = null;
        function openDeleteModal(event, form) {
            if (event) event.preventDefault();
            formToSubmit = form;
            const modal = document.getElementById('deleteConfirmModal');
            const content = document.getElementById('deleteConfirmModalContent');
            if (modal && content) {
                modal.classList.remove('hidden');
                setTimeout(() => {
                    content.classList.remove('scale-95', 'opacity-0');
                    content.classList.add('scale-100', 'opacity-100');
                }, 10);
            }
        }

        function closeDeleteModal() {
            const modal = document.getElementById('deleteConfirmModal');
            const content = document.getElementById('deleteConfirmModalContent');
            if (modal && content) {
                content.classList.remove('scale-100', 'opacity-100');
                content.classList.add('scale-95', 'opacity-0');
                setTimeout(() => {
                    modal.classList.add('hidden');
                    formToSubmit = null;
                }, 200);
            }
        }

        document.getElementById('confirmDeleteBtn')?.addEventListener('click', () => {
            if (formToSubmit) {
                formToSubmit.submit();
            }
        });
    </script>

    <!-- Footer -->
    <footer class="site-chrome bg-gray-50 border-t border-gray-200 mt-auto text-gray-700">
        <div class="max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4">

            <!-- Main Footer Links -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-y-10 py-12 border-b border-gray-200">
                <!-- Support Column -->
                <div class="flex flex-col gap-4">
                    <h3 class="font-semibold text-gray-900">Support</h3>
                    <a href="/help" class="hover:underline hover:text-gray-900 text-sm font-light">Help Centre</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">AirCover</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Anti-discrimination</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Disability support</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Cancellation options</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Report neighbourhood
                        concern</a>
                </div>

                <!-- Hosting Column -->
                <div class="flex flex-col gap-4">
                    <h3 class="font-semibold text-gray-900">Hosting</h3>
                    <a href="/hosting" class="hover:underline hover:text-gray-900 text-sm font-light">NullStay your
                        home</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">AirCover for Hosts</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Hosting resources</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Community forum</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Hosting responsibly</a>
                </div>

                <!-- NullStay Column -->
                <div class="flex flex-col gap-4">
                    <h3 class="font-semibold text-gray-900">NullStay</h3>
                    <a href="/careers" class="hover:underline hover:text-gray-900 text-sm font-light">Careers</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Investors</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Gift cards</a>
                </div>
            </div>

            <!-- Bottom Bar -->
            <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500 py-6">
                <div class="flex flex-row items-center gap-3 flex-wrap justify-center">
                    <span>© <%= new Date().getFullYear() %> NullStay, Inc.</span>
                    <span class="hidden md:inline">·</span>
                    <a href="/terms" class="hover:underline">Terms</a>
                    <span class="hidden md:inline">·</span>
                    <a href="/sitemap" class="hover:underline">Sitemap</a>
                    <span class="hidden md:inline">·</span>
                    <a href="/privacy" class="hover:underline">Privacy</a>
                    <span class="hidden md:inline">·</span>
                    <a href="/privacy-choices" class="hover:underline">Your Privacy Choices</a>
                </div>
                <div class="flex flex-row items-center gap-4 font-medium text-gray-900">
                    <a href="#" class="hover:underline flex items-center gap-1"><i class="fa-solid fa-globe"></i>
                        English (IN)</a>
                    <a href="#" class="hover:underline">&#8377; INR</a>
                    <a href="#" class="hover:underline"><i class="fa-brands fa-square-facebook text-xl"></i></a>
                    <a href="#" class="hover:underline"><i class="fa-brands fa-square-twitter text-xl"></i></a>
                    <a href="#" class="hover:underline"><i class="fa-brands fa-square-instagram text-xl"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <link rel="stylesheet" href="/css/ui-dialog.css">
    <script src="/js/nullstay-ui.js"></script>
    <script src="/js/script.js"></script>
    <script src="/js/newListing.js"></script>
    <% if (typeof isHomePage !== 'undefined' && isHomePage) { %>
    <script src="/js/home.js"></script>
    <script src="/js/home-mocks.js"></script>
    <% } %>
    <% if (currentUser) { %>
    <script>window.__NULLSTAY_USER_ID__ = "<%= currentUser._id %>";</script>
    <% if (typeof webPushEnabled !== 'undefined' && webPushEnabled && vapidPublicKey) { %>
    <script>window.__NULLSTAY_VAPID_KEY__ = "<%= vapidPublicKey %>";</script>
    <% } %>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/notifications.js"></script>
    <script src="/js/messages.js"></script>
    <script src="/js/wishlist.js"></script>
    <% } %>
</body>

</html>