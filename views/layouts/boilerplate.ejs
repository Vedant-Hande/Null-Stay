<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Null Stay - Vacation Rentals & Homes</title>
    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            color: #222222;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #f9fafb;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
            border: 2px solid #f9fafb;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        airbnb: '#ff385c',
                    }
                }
            }
        }
    </script>
</head>

<body class="min-h-screen flex flex-col bg-white custom-scroll relative">
    <!-- Search Backdrop Overlay -->
    <div id="searchBackdrop" class="fixed inset-0 bg-black/40 z-[60] hidden transition-opacity duration-300 opacity-0"></div>
    <!-- Navbar -->
    <nav class="sticky top-0 bg-white z-50 border-b border-gray-200">
        <div class="max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4">
            <div class="flex flex-row items-center justify-between py-3 gap-3 md:gap-0">

                <!-- Logo -->
                <div class="flex items-center">
                    <a href="/" class="flex items-center text-airbnb text-2xl font-bold">
                        <i class="fa-brands fa-airbnb text-3xl me-2"></i>
                        <span class="hidden lg:block">NullStay</span>
                    </a>
                </div>

                <!-- Search Bar Pill -->
                <div id="searchPill"
                    class="border border-gray-300 w-full md:w-auto py-2 rounded-full shadow-sm hover:shadow-md transition cursor-pointer z-[70] bg-white">
                    <div class="flex flex-row items-center justify-between">
                        <div class="text-sm font-semibold px-6">Anywhere</div>
                        <div
                            class="hidden sm:block text-sm font-semibold px-6 border-x border-gray-300 flex-1 text-center">
                            Any week</div>
                        <div class="text-sm pl-6 pr-2 text-gray-500 flex flex-row items-center gap-3">
                            <div class="hidden sm:block">Add guests</div>
                            <div class="p-2 bg-airbnb rounded-full text-white w-8 h-8 flex items-center justify-center">
                                <i class="fa-solid fa-magnifying-glass text-xs"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Expanded Search Bar (Airbnb Style) -->
                <div id="expandedSearch" class="hidden absolute top-[70px] left-1/2 -translate-x-1/2 w-full max-w-[850px] z-[70] px-4 md:px-0 transition-all duration-300 origin-top scale-95 opacity-0">
                    <div class="bg-gray-100 rounded-full border border-gray-200 shadow-2xl flex items-center p-1 overflow-hidden">
                        <!-- Location Section -->
                        <div class="flex-1 px-8 py-3 hover:bg-white hover:shadow-md rounded-full cursor-pointer transition group">
                            <label class="block text-[10px] font-bold text-gray-800 uppercase tracking-wider">Where</label>
                            <input type="text" placeholder="Search destinations" class="bg-transparent text-sm text-gray-900 w-full outline-none placeholder-gray-500">
                        </div>
                        
                        <div class="h-8 w-[1px] bg-gray-300"></div>

                        <!-- Dates Section -->
                        <div class="flex-1 px-8 py-3 hover:bg-white hover:shadow-md rounded-full cursor-pointer transition">
                            <label class="block text-[10px] font-bold text-gray-800 uppercase tracking-wider">Check in</label>
                            <span class="text-sm text-gray-400 font-normal">Add dates</span>
                        </div>

                        <div class="h-8 w-[1px] bg-gray-300"></div>

                        <div class="flex-1 px-8 py-3 hover:bg-white hover:shadow-md rounded-full cursor-pointer transition">
                            <label class="block text-[10px] font-bold text-gray-800 uppercase tracking-wider">Check out</label>
                            <span class="text-sm text-gray-400 font-normal">Add dates</span>
                        </div>

                        <div class="h-8 w-[1px] bg-gray-300"></div>

                        <!-- Guests Section -->
                        <div class="flex-1 px-8 py-3 hover:bg-white hover:shadow-md rounded-full cursor-pointer transition flex items-center justify-between">
                            <div>
                                <label class="block text-[10px] font-bold text-gray-800 uppercase tracking-wider">Who</label>
                                <span class="text-sm text-gray-400 font-normal">Add guests</span>
                            </div>
                            <button class="bg-airbnb hover:bg-rose-600 text-white rounded-full p-4 transition shadow-lg">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Right Menu -->
                <div class="hidden md:flex flex-row items-center gap-3">
                    <div
                        class="text-sm font-semibold py-3 px-4 rounded-full hover:bg-neutral-100 transition cursor-pointer">
                        <a href="/listings/new">Airbnb your home</a>
                    </div>
                    <div
                        class="p-2 px-4 border border-gray-300 rounded-full flex flex-row items-center gap-3 hover:shadow-md transition cursor-pointer">
                        <i class="fa-solid fa-bars text-sm"></i>
                        <div
                            class="bg-gray-500 rounded-full text-white overflow-hidden w-7 h-7 flex items-center justify-center">
                            <i class="fa-solid fa-user text-xs"></i>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- Categories Bar -->
        <div class="max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4 py-2">
            <div class="flex flex-row items-center justify-between overflow-x-auto gap-8 pt-1 hide-scrollbar">
                <div
                    class="flex flex-col items-center justify-center gap-2 pb-2 border-b-2 border-neutral-800 text-neutral-800 hover:text-neutral-800 cursor-pointer opacity-100 min-w-max">
                    <i class="fa-solid fa-water text-xl"></i>
                    <div class="text-sm font-medium">Amazing pools</div>
                </div>
                <div
                    class="flex flex-col items-center justify-center gap-2 pb-2 border-b-2 border-transparent text-neutral-500 hover:border-neutral-300 hover:text-neutral-800 cursor-pointer opacity-70 min-w-max transition">
                    <i class="fa-solid fa-umbrella-beach text-xl"></i>
                    <div class="text-sm font-medium">Beachfront</div>
                </div>
                <div
                    class="flex flex-col items-center justify-center gap-2 pb-2 border-b-2 border-transparent text-neutral-500 hover:border-neutral-300 hover:text-neutral-800 cursor-pointer opacity-70 min-w-max transition">
                    <i class="fa-brands fa-fort-awesome text-xl"></i>
                    <div class="text-sm font-medium">Castles</div>
                </div>
                <div
                    class="flex flex-col items-center justify-center gap-2 pb-2 border-b-2 border-transparent text-neutral-500 hover:border-neutral-300 hover:text-neutral-800 cursor-pointer opacity-70 min-w-max transition">
                    <i class="fa-solid fa-tree text-xl"></i>
                    <div class="text-sm font-medium">Treehouses</div>
                </div>
                <div
                    class="flex flex-col items-center justify-center gap-2 pb-2 border-b-2 border-transparent text-neutral-500 hover:border-neutral-300 hover:text-neutral-800 cursor-pointer opacity-70 min-w-max transition">
                    <i class="fa-solid fa-house-user text-xl"></i>
                    <div class="text-sm font-medium">Cabins</div>
                </div>
                <div
                    class="flex flex-col items-center justify-center gap-2 pb-2 border-b-2 border-transparent text-neutral-500 hover:border-neutral-300 hover:text-neutral-800 cursor-pointer opacity-70 min-w-max transition">
                    <i class="fa-solid fa-city text-xl"></i>
                    <div class="text-sm font-medium">Iconic cities</div>
                </div>
            </div>
            <style>
                .hide-scrollbar::-webkit-scrollbar {
                    display: none;
                }

                .hide-scrollbar {
                    -ms-overflow-style: none;
                    scrollbar-width: none;
                }
            </style>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4 py-8 w-full">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-50 border-t border-gray-200 mt-auto text-gray-700">
        <div class="max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4">

            <!-- Main Footer Links -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-y-10 py-12 border-b border-gray-200">
                <!-- Support Column -->
                <div class="flex flex-col gap-4">
                    <h3 class="font-semibold text-gray-900">Support</h3>
                    <a href="/help" class="hover:underline hover:text-gray-900 text-sm font-light">Help Centre</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">AirCover</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Anti-discrimination</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Disability support</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Cancellation options</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Report neighbourhood
                        concern</a>
                </div>

                <!-- Hosting Column -->
                <div class="flex flex-col gap-4">
                    <h3 class="font-semibold text-gray-900">Hosting</h3>
                    <a href="/hosting" class="hover:underline hover:text-gray-900 text-sm font-light">NullStay your home</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">AirCover for Hosts</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Hosting resources</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Community forum</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Hosting responsibly</a>
                </div>

                <!-- NullStay Column -->
                <div class="flex flex-col gap-4">
                    <h3 class="font-semibold text-gray-900">NullStay</h3>
                    <a href="/careers" class="hover:underline hover:text-gray-900 text-sm font-light">Careers</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Investors</a>
                    <a href="#" class="hover:underline hover:text-gray-900 text-sm font-light">Gift cards</a>
                </div>
            </div>

            <!-- Bottom Bar -->
            <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500 py-6">
                <div class="flex flex-row items-center gap-3 flex-wrap justify-center">
                    <span>© <%= new Date().getFullYear() %> NullStay, Inc.</span>
                    <span class="hidden md:inline">·</span>
                    <a href="/terms" class="hover:underline">Terms</a>
                    <span class="hidden md:inline">·</span>
                    <a href="/sitemap" class="hover:underline">Sitemap</a>
                    <span class="hidden md:inline">·</span>
                    <a href="/privacy" class="hover:underline">Privacy</a>
                    <span class="hidden md:inline">·</span>
                    <a href="/privacy-choices" class="hover:underline">Your Privacy Choices</a>
                </div>
                <div class="flex flex-row items-center gap-4 font-medium text-gray-900">
                    <a href="#" class="hover:underline flex items-center gap-1"><i class="fa-solid fa-globe"></i>
                        English (IN)</a>
                    <a href="#" class="hover:underline">&#8377; INR</a>
                    <a href="#" class="hover:underline"><i class="fa-brands fa-square-facebook text-xl"></i></a>
                    <a href="#" class="hover:underline"><i class="fa-brands fa-square-twitter text-xl"></i></a>
                    <a href="#" class="hover:underline"><i class="fa-brands fa-square-instagram text-xl"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="/js/script.js"></script>
</body>

</html>