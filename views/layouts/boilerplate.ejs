<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../includes/seoHead.ejs') %>
    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/utilities.css">
    <link rel="stylesheet" href="/css/notifications.css">
    <link rel="stylesheet" href="/css/wishlist.css">
    <% if (typeof isHomePage !== 'undefined' && isHomePage) { %>
    <link rel="stylesheet" href="/css/home.css">
    <% } %>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <!-- Google Fonts -->
    <% if (typeof isHomePage !== 'undefined' && isHomePage) { %>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <% } else { %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <% } %>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            color: #222222;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #f9fafb;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
            border: 2px solid #f9fafb;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        airbnb: '#ff385c',
                    }
                }
            }
        }
    </script>
</head>



<body class="min-h-screen flex flex-col bg-white custom-scroll relative<%= typeof isHomePage !== 'undefined' && isHomePage ? ' is-home-page' : '' %>">
    <div id="notificationToastStack" class="notification-toast-stack" aria-live="polite"></div>
    <%- include('../includes/desktopNotifyBanner.ejs') %>
    <!-- Search Backdrop Overlay -->
    <div id="searchBackdrop" class="fixed inset-0 bg-black/40 z-[60] hidden transition-opacity duration-300 opacity-0">
    </div>
    <!-- Expanded Search Panel -->
    <div id="expandedSearch"
        class="fixed top-24 left-1/2 -translate-x-1/2 z-[70] w-[95%] max-w-[850px] hidden opacity-0 scale-95 transition-all duration-300">
        <form action="/listings" method="GET"
            class="bg-white rounded-[32px] shadow-[0_6px_20px_rgba(0,0,0,0.2)] border border-gray-200 p-2 flex flex-col md:flex-row items-stretch md:items-center divide-y md:divide-y-0 md:divide-x divide-gray-200">
            <div class="flex-1 px-6 py-4">
                <label class="block text-xs font-bold text-gray-800 mb-1">Where</label>
                <input type="text" name="q" placeholder="Search destinations"
                    value="<%= typeof searchQuery !== 'undefined' && searchQuery.q ? searchQuery.q : '' %>"
                    class="w-full text-sm text-gray-600 placeholder-gray-400 outline-none bg-transparent" />
            </div>
            <div class="flex-1 px-6 py-4">
                <label class="block text-xs font-bold text-gray-800 mb-1">Country</label>
                <input type="text" name="country" placeholder="Any country"
                    value="<%= typeof searchQuery !== 'undefined' && searchQuery.country ? searchQuery.country : '' %>"
                    class="w-full text-sm text-gray-600 placeholder-gray-400 outline-none bg-transparent" />
            </div>
            <div class="px-6 py-4 w-full md:w-28">
                <label class="block text-xs font-bold text-gray-800 mb-1">Min price</label>
                <input type="number" name="minPrice" min="0" placeholder="₹"
                    value="<%= typeof searchQuery !== 'undefined' && searchQuery.minPrice ? searchQuery.minPrice : '' %>"
                    class="w-full text-sm text-gray-600 placeholder-gray-400 outline-none bg-transparent" />
            </div>
            <div class="px-6 py-4 w-full md:w-28">
                <label class="block text-xs font-bold text-gray-800 mb-1">Max price</label>
                <input type="number" name="maxPrice" min="0" placeholder="₹"
                    value="<%= typeof searchQuery !== 'undefined' && searchQuery.maxPrice ? searchQuery.maxPrice : '' %>"
                    class="w-full text-sm text-gray-600 placeholder-gray-400 outline-none bg-transparent" />
            </div>
            <div class="px-6 py-4 w-full md:w-24">
                <label class="block text-xs font-bold text-gray-800 mb-1">Guests</label>
                <input type="number" name="guests" min="1" placeholder="1"
                    value="<%= typeof searchQuery !== 'undefined' && searchQuery.guests ? searchQuery.guests : '' %>"
                    class="w-full text-sm text-gray-600 placeholder-gray-400 outline-none bg-transparent" />
            </div>
            <div class="p-2 flex items-center justify-center">
                <button type="submit"
                    class="bg-airbnb hover:bg-rose-600 text-white rounded-full p-4 flex items-center justify-center transition shadow-md">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
            </div>
        </form>
    </div>
    <!-- Navbar -->
    <div class="site-chrome">
    <nav class="sticky top-0 bg-white z-50 border-b border-gray-200">
        <div class="max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4">
            <div class="flex flex-row items-center justify-between py-3 gap-3 md:gap-0">

                <!-- Logo -->
                <div class="flex items-center">
                    <a href="/" class="flex items-center text-airbnb text-2xl font-bold">
                        <i class="fa-brands fa-airbnb text-3xl me-2"></i>
                        <span class="hidden lg:block">NullStay</span>
                    </a>
                </div>

                <!-- Search Bar Pill -->
                <div id="searchPill"
                    class="border border-gray-300 w-full md:w-auto py-2 rounded-full shadow-sm hover:shadow-md transition cursor-pointer z-[70] bg-white">
                    <div class="flex flex-row items-center justify-between">
                        <div class="text-sm font-semibold px-6">Anywhere</div>
                        <div
                            class="hidden sm:block text-sm font-semibold px-6 border-x border-gray-300 flex-1 text-center">
                            Any week</div>
                        <div class="text-sm pl-6 pr-2 text-gray-500 flex flex-row items-center gap-3">
                            <div class="hidden sm:block">Add guests</div>
                            <div class="p-2 bg-airbnb rounded-full text-white w-8 h-8 flex items-center justify-center">
                                <i class="fa-solid fa-magnifying-glass text-xs"></i>
                            </div>
                        </div>
                    </div>
                </div>



                <!-- Right Menu -->
                <div class="flex flex-row items-center gap-1 md:gap-3">

                    <div
                        class="text-sm font-semibold py-3 px-3 sm:px-4 rounded-full hover:bg-neutral-100 transition cursor-pointer hidden sm:block">
                        <a href="/listings">Properties</a>
                    </div>
                    <div
                        class="text-sm font-semibold py-3 px-3 sm:px-4 rounded-full hover:bg-neutral-100 transition cursor-pointer hidden sm:block">
                        <a href="/listings/new">+ Add your property</a>
                    </div>
                    <% if (!currentUser) { %>
                        <div
                            class="text-sm font-semibold py-3 px-3 sm:px-4 rounded-full hover:bg-neutral-100 transition cursor-pointer hidden sm:block">
                            <a href="/login">Log in</a>
                        </div>
                        <% } else { %>
                            <%- include('../includes/notificationPanel.ejs') %>
                            <% } %>

                            <div class="relative">
                                <div id="userMenuBtn"
                                    class="p-2 px-4 border border-gray-300 rounded-full flex flex-row items-center gap-3 hover:shadow-md transition cursor-pointer bg-white">
                                    <i class="fa-solid fa-bars text-sm"></i>
