<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../includes/seoHead.ejs') %>
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="stylesheet" href="/css/utilities.css">
        <link rel="stylesheet" href="/css/site-footer.css">
        <link rel="stylesheet" href="/css/home.css">
        <link rel="stylesheet" href="/css/landing-pages.css">
        <link rel="stylesheet" href="/css/brand.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
        <link
            href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet">
        <style>
            body {
                font-family: 'Inter', sans-serif;
                color: #222222;
                overflow-x: clip;
            }
        </style>
        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: { airbnb: '#ff385c' }
                    }
                }
            }
        </script>
</head>

<body class="min-h-screen flex flex-col bg-white custom-scroll is-landing-page">
    <div id="notificationToastStack" class="notification-toast-stack" aria-live="polite"></div>

    <div class="ns-land ns-land--static flex flex-col flex-grow">
        <%- include('../includes/landingNav.ejs') %>

            <% if (success && success.length) { %>
                <div class="ns-flash">
                    <div class="flash-success">
                        <%= success %>
                    </div>
                </div>
                <% } %>
                    <% if (error && error.length) { %>
                        <div class="ns-flash">
                            <div class="flash-error">
                                <%= error %>
                            </div>
                        </div>
                        <% } %>

                            <main class="ns-land-main flex-grow">
                                <%- body %>
                            </main>
    </div>

    <%- include('../includes/landingFooter.ejs') %>

        <link rel="stylesheet" href="/css/ui-dialog.css">
        <script src="/js/nullstay-ui.js"></script>
        <script src="/js/landing.js"></script>
        <% if (currentUser) { %>
            <script>window.__NULLSTAY_USER_ID__ = "<%= currentUser._id %>";</script>
            <% if (typeof webPushEnabled !==='undefined' && webPushEnabled && vapidPublicKey) { %>
                <script>window.__NULLSTAY_VAPID_KEY__ = "<%= vapidPublicKey %>";</script>
                <% } %>
                    <script src="/socket.io/socket.io.js"></script>
                    <script src="/js/notifications.js"></script>
                    <% } %>
</body>

</html>