<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Listing</title>
</head>

<body>
    <h1>Create New Listing</h1>
    <form action="/listings" method="POST">
        <div>
            <label for="title">Title:</label>
            <input type="text" id="title" name="listing[title]" required maxlength="50">
        </div>

        <div>
            <label for="desc">Description:</label>
            <textarea id="desc" name="listing[desc]" required maxlength="500" rows="4"></textarea>
        </div>

        <div>
            <label for="image">Image URL:</label>
            <input type="url" id="image" name="listing[image][url]" placeholder="Enter image URL (optional)">
        </div>

        <div>
            <label for="price">Price:</label>
            <input type="number" id="price" name="listing[price]" required min="0">
        </div>

        <div>
            <label for="location">Location:</label>
            <input type="text" id="location" name="listing[location]" required maxlength="100">
        </div>

        <div>
            <label for="country">Country:</label>
            <input type="text" id="country" name="listing[country]" required maxlength="50">
        </div>

        <button type="submit">Create Listing</button>
    </form>
</body>

</html>