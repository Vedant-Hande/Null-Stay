<% layout("/layouts/boilerplate") %>

<div class="max-w-[600px] mx-auto py-10 px-4">
    <div class="border border-gray-200 rounded-2xl shadow-xl bg-white overflow-hidden">
        <!-- Form Header -->
        <div class="border-b border-gray-200 px-6 py-4 flex justify-center items-center">
            <h1 class="text-base font-bold text-gray-900">Create a new listing</h1>
        </div>

        <!-- Form Body -->
        <div class="p-6 md:p-8">
            <h2 class="text-2xl font-semibold mb-6">Welcome to NullStay</h2>
            
            <form action="/listings" method="POST" class="flex flex-col gap-5">
                
                <div class="border border-gray-400 rounded-lg overflow-hidden focus-within:border-black focus-within:ring-1 focus-within:ring-black transition">
                    <div class="relative px-3 py-2">
                        <label for="title" class="absolute text-[10px] uppercase font-bold text-gray-500 top-1.5">Property Title</label>
                        <input type="text" id="title" name="listing[title]" required maxlength="50" class="w-full pt-4 pb-1 outline-none text-gray-900 bg-transparent placeholder-gray-300" placeholder="e.g. Stunning Beachfront Villa">
                    </div>
                </div>

                <div class="border border-gray-400 rounded-lg overflow-hidden focus-within:border-black focus-within:ring-1 focus-within:ring-black transition">
                    <div class="relative px-3 py-2">
                        <label for="desc" class="absolute text-[10px] uppercase font-bold text-gray-500 top-1.5">Description</label>
                        <textarea id="desc" name="listing[desc]" required maxlength="500" rows="3" class="w-full pt-4 pb-1 outline-none text-gray-900 bg-transparent placeholder-gray-300 resize-none" placeholder="Describe what makes your place unique..."></textarea>
                    </div>
                </div>

                <div class="border border-gray-400 rounded-lg overflow-hidden focus-within:border-black focus-within:ring-1 focus-within:ring-black transition">
                    <div class="relative px-3 py-2">
                        <label for="image" class="absolute text-[10px] uppercase font-bold text-gray-500 top-1.5">Image URL</label>
                        <input type="url" id="image" name="listing[image][url]" class="w-full pt-4 pb-1 outline-none text-gray-900 bg-transparent placeholder-gray-300" placeholder="https://...">
                    </div>
                </div>

                <div class="flex flex-col md:flex-row gap-5">
                    <div class="flex-1 border border-gray-400 rounded-lg overflow-hidden focus-within:border-black focus-within:ring-1 focus-within:ring-black transition">
                        <div class="relative px-3 py-2">
                            <label for="price" class="absolute text-[10px] uppercase font-bold text-gray-500 top-1.5">Price (per night)</label>
                            <input type="number" id="price" name="listing[price]" required min="0" class="w-full pt-4 pb-1 outline-none text-gray-900 bg-transparent placeholder-gray-300" placeholder="₹0">
                        </div>
                    </div>
                    <div class="flex-1 border border-gray-400 rounded-lg overflow-hidden focus-within:border-black focus-within:ring-1 focus-within:ring-black transition">
                        <div class="relative px-3 py-2">
                            <label for="country" class="absolute text-[10px] uppercase font-bold text-gray-500 top-1.5">Country</label>
                            <input type="text" id="country" name="listing[country]" required maxlength="50" class="w-full pt-4 pb-1 outline-none text-gray-900 bg-transparent placeholder-gray-300" placeholder="e.g. India">
                        </div>
                    </div>
                </div>

                <div class="border border-gray-400 rounded-lg overflow-hidden focus-within:border-black focus-within:ring-1 focus-within:ring-black transition">
                    <div class="relative px-3 py-2">
                        <label for="location" class="absolute text-[10px] uppercase font-bold text-gray-500 top-1.5">Location (City, State)</label>
                        <input type="text" id="location" name="listing[location]" required maxlength="100" class="w-full pt-4 pb-1 outline-none text-gray-900 bg-transparent placeholder-gray-300" placeholder="e.g. Goa">
                    </div>
                </div>

                <div class="border-t border-gray-200 mt-2 pt-6">
                    <button type="submit" class="w-full bg-airbnb hover:bg-rose-600 text-white font-semibold py-3.5 rounded-lg transition text-lg">
                        Publish Listing
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>