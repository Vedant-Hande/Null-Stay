<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | NullStay Dev</title>
  <style>
    :root { --rose: #ff385c; --ink: #222; --muted: #717171; --bg: #fafafa; --card: #fff; --border: #ebebeb; }
    * { box-sizing: border-box; }
    body { font-family: system-ui, -apple-system, Segoe UI, sans-serif; margin: 0; background: var(--bg); color: var(--ink); line-height: 1.5; }
    .wrap { max-width: 960px; margin: 0 auto; padding: 2rem 1.25rem 3rem; }
    h1 { font-size: 1.5rem; margin: 0 0 0.25rem; }
    .sub { color: var(--muted); font-size: 0.9rem; margin-bottom: 1.5rem; }
    .hero { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.1rem; }
    .stat strong { display: block; font-size: 1.75rem; color: var(--rose); }
    .stat span { font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; }
    section { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
    h2 { font-size: 1rem; margin: 0 0 0.75rem; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th, td { text-align: left; padding: 0.45rem 0.5rem; border-bottom: 1px solid var(--border); }
    th { color: var(--muted); font-weight: 600; font-size: 0.75rem; text-transform: uppercase; }
    tr:last-child td { border-bottom: none; }
    .pill { display: inline-block; background: #fff0f3; color: var(--rose); font-size: 0.75rem; padding: 0.15rem 0.5rem; border-radius: 999px; }
    footer { margin-top: 1.5rem; font-size: 0.8rem; color: var(--muted); }
    a { color: var(--rose); }
  </style>
</head>
<body>
  <div class="wrap">
    <p class="pill">Developer only</p>
    <h1>Project lines of code</h1>
    <p class="sub">Generated <%= stats.generatedAt %> · <%= stats.totals.files %> files scanned</p>

    <div class="hero">
      <div class="stat"><strong><%= stats.totals.code.toLocaleString() %></strong><span>Lines of code</span></div>
      <div class="stat"><strong><%= stats.totals.total.toLocaleString() %></strong><span>Total lines</span></div>
      <div class="stat"><strong><%= stats.totals.blank.toLocaleString() %></strong><span>Blank lines</span></div>
      <div class="stat"><strong><%= stats.totals.comment.toLocaleString() %></strong><span>Comment lines</span></div>
    </div>

    <section>
      <h2>By folder</h2>
      <table>
        <thead><tr><th>Folder</th><th>Files</th><th>Code</th><th>Total</th></tr></thead>
        <tbody>
          <% Object.entries(stats.byTopLevelFolder).forEach(([name, row]) => { %>
            <tr>
              <td><%= name %></td>
              <td><%= row.files %></td>
              <td><%= row.code.toLocaleString() %></td>
              <td><%= row.total.toLocaleString() %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </section>

    <section>
      <h2>By file type</h2>
      <table>
        <thead><tr><th>Extension</th><th>Files</th><th>Code</th><th>Total</th></tr></thead>
        <tbody>
          <% Object.entries(stats.byExtension).forEach(([name, row]) => { %>
            <tr>
              <td><%= name %></td>
              <td><%= row.files %></td>
              <td><%= row.code.toLocaleString() %></td>
              <td><%= row.total.toLocaleString() %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </section>

    <footer>
      <a href="/dev/loc<%= keyParam %>&format=json">JSON export</a> ·
      <a href="/dev/loc<%= keyParam %>&format=html">HTML view</a>
      Routes, views, public, utils, models, docs, and related project folders only — not <code>node_modules</code>.
    </footer>
  </div>
</body>
</html>
