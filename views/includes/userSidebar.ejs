      <span class="text-sm">Trips</span>
    </a>
    <a href="/bookings/host"
      class="flex items-center gap-3.5 px-4 py-3 text-gray-600 hover:bg-gray-50 hover:text-gray-900 font-semibold rounded-xl transition duration-200">
