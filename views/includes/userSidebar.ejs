      <span class="text-sm">Add New Listing</span>
    </a>
    <div class="border-t border-gray-100 my-2"></div>
    <a href="/logout"
      class="flex items-center gap-3.5 px-4 py-3 text-rose-600 hover:bg-rose-50 font-semibold rounded-xl transition duration-200">
      <i class="fa-solid fa-arrow-right-from-bracket text-base"></i>
      <span class="text-sm">Log out</span>
    </a>
