<%
  const fieldId = typeof uploadId !== "undefined" ? uploadId : "image";
  const isRequired = typeof required !== "undefined" && required;
  const existingUrl = typeof currentImageUrl !== "undefined" ? currentImageUrl : "";
  const hintText = typeof hint !== "undefined" ? hint : "JPG, PNG or WEBP · Max 5MB";
%>
<div class="image-upload-field" data-initial-url="<%= existingUrl %>">
    <p class="text-[10px] uppercase font-bold text-gray-500 mb-3 tracking-wide">Property Photo</p>

    <input type="file" id="<%= fieldId %>" name="image" accept="image/jpeg,image/png,image/webp,image/gif"
        class="image-upload-input sr-only" <%= isRequired ? "required" : "" %>>

    <div
        class="image-upload-dropzone relative flex flex-col items-center justify-center gap-3 rounded-xl border-2 border-dashed border-gray-300 bg-gray-50/80 px-6 py-10 text-center transition cursor-pointer hover:border-gray-400 hover:bg-white focus-within:border-black focus-within:ring-2 focus-within:ring-black/10"
        role="button" tabindex="0" aria-label="Upload property photo">
        <!-- Empty state -->
        <div class="upload-empty-state flex flex-col items-center gap-3 <%= existingUrl ? 'hidden' : '' %>">
            <div
                class="flex h-14 w-14 items-center justify-center rounded-full bg-rose-50 text-[#FF385C] shadow-sm ring-4 ring-white">
                <i class="fa-solid fa-cloud-arrow-up text-2xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-700">
                    <span class="font-semibold text-[#FF385C]">Click to upload</span>
                    <span class="text-gray-500"> or drag and drop</span>
                </p>
                <p class="mt-1 text-xs text-gray-400">
                    <%= hintText %>
                </p>
            </div>
        </div>

        <!-- Preview state -->
        <div class="upload-preview-state w-full <%= existingUrl ? '' : 'hidden' %>">
            <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-5">
                <div class="relative shrink-0 overflow-hidden rounded-xl border border-gray-200 shadow-sm">
                    <img src="<%= existingUrl || '' %>" alt="Preview"
                        class="upload-preview-img h-28 w-40 sm:h-32 sm:w-44 object-cover bg-gray-100">
                    <span
                        class="absolute bottom-2 left-2 rounded-md bg-black/60 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-white">Preview</span>
                </div>
                <div class="min-w-0 flex-1 text-left">
                    <p class="upload-preview-name truncate text-sm font-semibold text-gray-900">
                        <%= existingUrl ? "Current photo" : "Selected image" %>
                    </p>
                    <p class="upload-preview-size mt-0.5 text-xs text-gray-500">
                        <%= existingUrl ? "Upload a new file to replace" : "" %>
                    </p>
                    <div class="mt-3 flex flex-wrap gap-2">
                        <button type="button"
                            class="upload-change-btn inline-flex items-center gap-1.5 rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 transition hover:border-gray-900 hover:bg-gray-50">
                            <i class="fa-solid fa-arrows-rotate text-[10px]"></i> Change
                        </button>
                        <button type="button"
                            class="upload-remove-btn inline-flex items-center gap-1.5 rounded-lg border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-600 transition hover:bg-red-100">
                            <i class="fa-solid fa-xmark text-[10px]"></i> Remove
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="invalid-feedback">Please upload a property image.</div>
    <% if (!isRequired) { %>
        <p class="mt-2 text-xs text-gray-400">Leave empty to keep your current image.</p>
    <% } %>
</div>
