<!-- Full-Screen Reviews Modal -->
<div id="reviewsModal" class="fixed inset-0 z-[100] bg-white hidden overflow-y-auto">
    <div class="max-w-[1120px] mx-auto px-4 py-8">
        <button type="button" onclick="closeReviews()"
            class="w-10 h-10 rounded-full hover:bg-gray-100 flex items-center justify-center text-xl mb-8 transition">
            <i class="fa-solid fa-xmark"></i>
        </button>
        <h2 class="text-3xl font-bold mb-8">
            <i class="fa-solid fa-star"></i> 
            <%= calculateAvgRating(listing.reviews) || "0.0" %> · <%= listing.reviews.length %> reviews
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
            <% if (listing.reviews && listing.reviews.length > 0) { %>
                <% listing.reviews.forEach(review => { %>
                    <div class="flex flex-col gap-3">
                        <div class="flex items-center gap-4 justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-neutral-900 text-white flex items-center justify-center font-bold text-lg">
                                    <%= (review.owner && review.owner.username) ? review.owner.username.charAt(0).toUpperCase() : ((review.author && review.author.username) ? review.author.username.charAt(0).toUpperCase() : 'G') %>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-gray-900">
                                        <%= (review.owner && review.owner.username) ? review.owner.username : ((review.author && review.author.username) ? review.author.username : 'Guest') %>
                                    </h4>
                                    <div class="text-sm text-gray-500">
                                        <%= new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) %>
                                    </div>
                                </div>
                            </div>
                            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="mt-0">
                                <button type="submit" aria-label="Delete review" class="text-red-500 hover:text-black transition">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>
                        </div>
                        <div class="flex text-yellow-400 text-xs gap-0.5">
                            <% for (let i=0; i < review.rating; i++) { %>
                                <i class="fa-solid fa-star"></i>
                            <% } %>
                            <% for (let i=review.rating; i < 5; i++) { %>
                                <i class="fa-regular fa-star"></i>
                            <% } %>
                        </div>
                        <p class="text-gray-700 leading-relaxed font-light">
                            "<%= review.comment %>"
                        </p>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-full text-center text-gray-500 py-8">No reviews yet.</div>
            <% } %>
        </div>
    </div>
</div>
