<!-- Full-Screen Photos Modal -->
<div id="photosModal" class="fixed inset-0 z-[110] bg-white hidden flex flex-col">
    <!-- Top Nav -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white sticky top-0 z-10">
        <button type="button" onclick="closePhotosModal()"
            class="w-10 h-10 rounded-full hover:bg-gray-100 flex items-center justify-center text-xl transition">
            <i class="fa-solid fa-chevron-left"></i>
        </button>
        <div class="flex gap-4">
            <button
                class="flex items-center gap-2 px-3 py-1.5 rounded-lg hover:bg-gray-100 transition font-medium text-sm underline">
                <i class="fa-solid fa-arrow-up-from-bracket"></i> Share
            </button>
            <button
                class="flex items-center gap-2 px-3 py-1.5 rounded-lg hover:bg-gray-100 transition font-medium text-sm underline">
                <i class="fa-regular fa-heart"></i> Save
            </button>
        </div>
    </div>

    <!-- Scrollable Photo Grid -->
    <div class="flex-1 overflow-y-auto px-4 md:px-20 lg:px-40 py-8 bg-gray-50 pb-20">
        <div class="flex flex-col gap-4 max-w-4xl mx-auto">
            <!-- Cover photo -->
            <div class="w-full h-auto md:h-[60vh] rounded-xl overflow-hidden mb-2 shadow-sm">
                <img src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80' %>"
                    alt="<%= listing.title %> cover" class="w-full h-full object-cover">
            </div>

            <% if (listing.images && listing.images.length) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% listing.images.forEach((img, index)=> { %>
                        <div
                            class="rounded-xl overflow-hidden h-64 md:h-80 shadow-sm border border-gray-200 <%= index === listing.images.length - 1 && listing.images.length % 2 !=== 0 ? 'md:col-span-2 md:h-96' : '' %>">
                            <img src="<%= img.url %>" alt="<%= listing.title %> photo <%= index + 1 %>"
                                class="w-full h-full object-cover hover:scale-105 transition duration-500">
                        </div>
                        <% }) %>
                </div>
                <% } %>
        </div>
    </div>
</div>