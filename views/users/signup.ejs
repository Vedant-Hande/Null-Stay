<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/validation.css">

<div class="max-w-[1000px] mx-auto py-12 px-4 sm:px-6 lg:px-8 flex items-center justify-center min-h-[80vh]">
    <div class="flex flex-col lg:flex-row bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100 w-full">
        
        <!-- Left Banner -->
        <div class="lg:w-1/2 relative bg-gradient-to-br from-rose-500 to-airbnb p-10 md:p-12 flex flex-col justify-between text-white overflow-hidden">
            <div class="relative z-10 h-full flex flex-col justify-center">
                <i class="fa-brands fa-airbnb text-5xl mb-6"></i>
                <h2 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">Join the NullStay community</h2>
                <p class="text-lg opacity-90 leading-relaxed">
                    Discover amazing places, create unforgettable memories, and connect with hosts all around the world.
                </p>
            </div>

            <!-- Decorative background elements -->
            <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
            <div class="absolute -top-20 -left-20 w-48 h-48 bg-black/10 rounded-full blur-2xl"></div>
        </div>

        <!-- Right Form Section -->
        <div class="lg:w-1/2 p-10 md:p-14 bg-white flex flex-col justify-center relative">
            <div class="mb-8">
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Create an account</h3>
                <p class="text-gray-500">Welcome to NullStay. Please enter your details.</p>
            </div>

            <!-- Auth Buttons -->
            <div class="flex flex-col gap-3 mb-6">
                <a href="/auth/google" class="w-full bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 font-semibold py-3.5 px-4 rounded-xl transition duration-300 shadow-sm flex items-center justify-center gap-3">
                    <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" class="w-5 h-5">
                    <span>Continue with Google</span>
                </a>
                
                <a href="/auth/instagram" class="w-full bg-gradient-to-r from-[#f9ce34] via-[#ee2a7b] to-[#6228d7] hover:opacity-90 text-white font-semibold py-3.5 px-4 rounded-xl transition duration-300 shadow-sm flex items-center justify-center gap-3">
                    <i class="fa-brands fa-instagram text-xl"></i>
                    <span>Continue with Instagram</span>
                </a>
            </div>

            <!-- Divider -->
            <div class="relative flex items-center justify-center mb-6">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-gray-200"></div>
                </div>
                <div class="relative bg-white px-4 text-sm text-gray-500 font-medium">Or sign up with email</div>
            </div>

            <form action="/signup" method="POST" class="space-y-6 needs-validation" novalidate>
                
                <!-- Username Field -->
                <div>
                    <label for="username" class="block text-sm font-semibold text-gray-800 mb-2">Username</label>
                    <div class="relative">
                        <div class="absolute top-0 left-0 h-[50px] pl-4 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-regular fa-user"></i>
                        </div>
                        <input type="text" id="username" name="username" required
                            class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-airbnb/50 focus:border-airbnb focus:bg-white transition-all shadow-sm"
                            placeholder="johndoe123">
                        <div class="valid-feedback text-sm text-green-600 mt-1.5">Looks good!</div>
                        <div class="invalid-feedback text-sm text-red-500 mt-1.5">Please enter a valid username.</div>
                    </div>
                </div>

                <!-- Email Field -->
                <div>
                    <label for="email" class="block text-sm font-semibold text-gray-800 mb-2">Email address</label>
                    <div class="relative">
                        <div class="absolute top-0 left-0 h-[50px] pl-4 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-regular fa-envelope"></i>
                        </div>
                        <input type="email" id="email" name="email" required
                            class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-airbnb/50 focus:border-airbnb focus:bg-white transition-all shadow-sm"
                            placeholder="john@example.com">
                        <div class="valid-feedback text-sm text-green-600 mt-1.5">Looks good!</div>
                        <div class="invalid-feedback text-sm text-red-500 mt-1.5">Please enter a valid email.</div>
                    </div>
                </div>

                <!-- Password Field -->
                <div>
                    <label for="password" class="block text-sm font-semibold text-gray-800 mb-2">Password</label>
                    <div class="relative">
                        <div class="absolute top-0 left-0 h-[50px] pl-4 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-lock"></i>
                        </div>
                        <input type="password" id="password" name="password" required minlength="6"
                            class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-airbnb/50 focus:border-airbnb focus:bg-white transition-all shadow-sm"
                            placeholder="••••••••">
                        <div class="valid-feedback text-sm text-green-600 mt-1.5">Looks good!</div>
                        <div class="invalid-feedback text-sm text-red-500 mt-1.5">Password must be at least 6 characters.</div>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit"
                    class="w-full bg-airbnb hover:bg-rose-600 text-white font-semibold py-3.5 px-4 rounded-xl transition duration-300 shadow-lg shadow-airbnb/30 mt-4 flex items-center justify-center gap-2 group">
                    <span>Sign up</span>
                    <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
                </button>
            </form>

            <div class="mt-8 text-center text-sm text-gray-600">
                Already have an account? 
                <a href="/login" class="font-semibold text-airbnb hover:underline transition">Log in here</a>
            </div>
        </div>
    </div>
</div>
