<% layout("/layouts/boilerplate") %>

<!-- Add Inter Google Font for ultra-modern typography -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  body {
    font-family: 'Inter', sans-serif;
    background-color: #fafafa;
  }
  .glass-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(229, 231, 235, 0.6);
  }
</style>

<div class="max-w-[1240px] mx-auto pb-16 pt-8 px-4 md:px-0 select-none">
  <!-- Top Banner / Page Header matching exactly the NullStay theme with a white background -->
  <div class="relative overflow-hidden rounded-3xl bg-white border border-gray-200 p-8 md:p-12 mb-10 shadow-sm flex flex-col md:flex-row md:items-center md:justify-between gap-8 select-none">
    <!-- Glowing background accent -->
    <div class="absolute -right-20 -top-20 w-[380px] h-[380px] bg-airbnb/5 rounded-full blur-[130px] pointer-events-none"></div>
    <div class="absolute -left-20 -bottom-20 w-[380px] h-[380px] bg-rose-900/5 rounded-full blur-[130px] pointer-events-none"></div>
    
    <div class="absolute -right-10 -top-10 opacity-5 pointer-events-none group-hover:scale-105 transition duration-500">
      <i class="fa-solid fa-chart-line text-[240px] text-gray-900"></i>
    </div>

    <div class="relative z-10 max-w-2xl">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-rose-50 border border-rose-100 rounded-full text-xs font-semibold text-airbnb mb-4 shadow-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-airbnb animate-pulse"></span> Performance Dashboard
      </span>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-gray-900">
        NullStay Host Insights
      </h1>
      <p class="text-gray-600 mt-2 font-light text-sm md:text-base leading-relaxed max-w-xl">
        Monitor your properties, view feedback statistics, and enhance your guest experience with real-time analytics.
      </p>
    </div>
    <div class="relative z-10 flex-shrink-0">
      <a href="/listings/new"
        class="inline-flex items-center gap-2 bg-airbnb hover:bg-rose-600 text-white px-6 py-3.5 rounded-xl font-extrabold tracking-wide shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition duration-300">
        <i class="fa-solid fa-plus"></i>
        <span>Add New Listing</span>
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-10">
    <!-- Left Navigation Sidebar -->
    <%- include("../includes/userSidebar.ejs", { activeTab: "analytics" }) %>

    <!-- Right Content Area -->
    <div class="md:col-span-8 lg:col-span-9 flex flex-col gap-6">
      <!-- Bento Grid Stats Section -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
    <!-- Stat 1: Total Listings -->
    <div class="glass-card p-6 rounded-2xl shadow-sm hover:shadow-md hover:-translate-y-1 transition duration-300 flex flex-col justify-between h-[165px] relative overflow-hidden group">
      <div class="absolute -right-6 -bottom-6 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition duration-500">
        <i class="fa-solid fa-house text-[130px] text-airbnb"></i>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Total Listings</span>
        <div class="w-11 h-11 rounded-2xl bg-rose-50 border border-rose-100 text-airbnb flex items-center justify-center shadow-sm">
          <i class="fa-solid fa-house text-lg"></i>
        </div>
      </div>
      <div>
        <h3 class="text-4xl font-extrabold tracking-tight text-gray-900 mt-2"><%= userListings.length %></h3>
        <p class="text-xs text-gray-500 mt-1 font-medium">Active rental properties</p>
      </div>
    </div>

    <!-- Stat 2: Total Reviews -->
    <div class="glass-card p-6 rounded-2xl shadow-sm hover:shadow-md hover:-translate-y-1 transition duration-300 flex flex-col justify-between h-[165px] relative overflow-hidden group">
      <div class="absolute -right-6 -bottom-6 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition duration-500">
        <i class="fa-solid fa-comments text-[130px] text-blue-600"></i>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Reviews Received</span>
        <div class="w-11 h-11 rounded-2xl bg-blue-50 border border-blue-100 text-blue-600 flex items-center justify-center shadow-sm">
          <i class="fa-solid fa-comments text-lg"></i>
        </div>
      </div>
      <div>
        <h3 class="text-4xl font-extrabold tracking-tight text-gray-900 mt-2"><%= totalReviewsReceived %></h3>
        <p class="text-xs text-gray-500 mt-1 font-medium">Feedback from guests</p>
      </div>
    </div>

    <!-- Stat 3: Average Rating -->
    <div class="glass-card p-6 rounded-2xl shadow-sm hover:shadow-md hover:-translate-y-1 transition duration-300 flex flex-col justify-between h-[165px] relative overflow-hidden group">
      <div class="absolute -right-6 -bottom-6 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition duration-500">
        <i class="fa-solid fa-star text-[130px] text-amber-500"></i>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Average Rating</span>
        <div class="w-11 h-11 rounded-2xl bg-amber-50 border border-amber-100 text-amber-500 flex items-center justify-center shadow-sm">
          <i class="fa-solid fa-star text-lg"></i>
        </div>
      </div>
      <div>
        <h3 class="text-4xl font-extrabold tracking-tight text-gray-900 mt-2">
          <%= averageRating === 'N/A' ? 'N/A' : averageRating + ' / 5.0' %>
        </h3>
        <p class="text-xs text-gray-500 mt-1 font-medium">Host rating across listings</p>
      </div>
    </div>

    <!-- Stat 4: Reviews Submitted -->
    <div class="glass-card p-6 rounded-2xl shadow-sm hover:shadow-md hover:-translate-y-1 transition duration-300 flex flex-col justify-between h-[165px] relative overflow-hidden group">
      <div class="absolute -right-6 -bottom-6 opacity-5 group-hover:opacity-10 group-hover:scale-110 transition duration-500">
        <i class="fa-solid fa-pen-nib text-[130px] text-emerald-600"></i>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Reviews Written</span>
        <div class="w-11 h-11 rounded-2xl bg-emerald-50 border border-emerald-100 text-emerald-600 flex items-center justify-center shadow-sm">
          <i class="fa-solid fa-pen-nib text-lg"></i>
        </div>
      </div>
      <div>
        <h3 class="text-4xl font-extrabold tracking-tight text-gray-900 mt-2"><%= reviewsSubmitted.length %></h3>
        <p class="text-xs text-gray-500 mt-1 font-medium">Authored reviews left across site</p>
      </div>
    </div>
  </div>

  <!-- Charts Section -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-12">
    <!-- Chart 1: Average Rating per Listing -->
    <div class="glass-card p-6 md:p-8 rounded-3xl shadow-sm hover:shadow-md transition">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">Rating per Listing</h3>
          <p class="text-xs text-gray-500 font-light mt-0.5">Rating performance breakdown by individual property</p>
        </div>
        <div class="w-9 h-9 rounded-xl bg-rose-50 border border-rose-100 text-airbnb flex items-center justify-center shadow-sm">
          <i class="fa-solid fa-chart-simple text-sm"></i>
        </div>
      </div>
      <div class="relative w-full h-[280px]">
        <canvas id="ratingsChart"></canvas>
      </div>
    </div>

    <!-- Chart 2: Reviews per Listing -->
    <div class="glass-card p-6 md:p-8 rounded-3xl shadow-sm hover:shadow-md transition">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">Reviews per Listing</h3>
          <p class="text-xs text-gray-500 font-light mt-0.5">Guest feedback volume breakdown by individual property</p>
        </div>
        <div class="w-9 h-9 rounded-xl bg-blue-50 border border-blue-100 text-blue-600 flex items-center justify-center shadow-sm">
          <i class="fa-solid fa-chart-pie text-sm"></i>
        </div>
      </div>
      <div class="relative w-full h-[280px]">
        <canvas id="reviewsChart"></canvas>
      </div>
    </div>
  </div>

  <%
    let chartListingTitles = [];
    let chartListingRatings = [];
    let chartListingReviewCounts = [];
    userListings.forEach((l, idx) => {
      let titlePrefix = `P${idx + 1}`;
      let shortTitle = l.title.length > 14 ? l.title.substring(0, 11) + "..." : l.title;
      chartListingTitles.push(`${titlePrefix}: ${shortTitle}`);
      let totalRev = l.reviews ? l.reviews.length : 0;
      let sum = 0;
      if (l.reviews) {
        l.reviews.forEach(r => { sum += r.rating; });
      }
      let avg = totalRev > 0 ? (sum / totalRev) : 0;
      chartListingRatings.push(avg.toFixed(1));
      chartListingReviewCounts.push(totalRev);
    });
  %>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const titles = <%- JSON.stringify(chartListingTitles) %>;
      const ratings = <%- JSON.stringify(chartListingRatings) %>;
      const reviews = <%- JSON.stringify(chartListingReviewCounts) %>;

      // Chart 1: Ratings
      new Chart(document.getElementById('ratingsChart'), {
        type: 'bar',
        data: {
          labels: titles,
          datasets: [{
            label: 'Average Rating',
            data: ratings,
            backgroundColor: 'rgba(255, 56, 92, 0.75)',
            borderColor: 'rgba(255, 56, 92, 1)',
            borderWidth: 1.5,
            borderRadius: 12,
            maxBarThickness: 34
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: {
              beginAtZero: true,
              max: 5,
              grid: {
                color: 'rgba(0, 0, 0, 0.04)'
              },
              ticks: {
                stepSize: 1,
                font: { size: 11, weight: '500' }
              }
            },
            x: {
              grid: {
                display: false
              },
              ticks: {
                display: false
              }
            }
          },
          plugins: {
            legend: { display: false }
          }
        }
      });

      // Chart 2: Reviews Count
      new Chart(document.getElementById('reviewsChart'), {
        type: 'bar',
        data: {
          labels: titles,
          datasets: [{
            label: 'Total Reviews',
            data: reviews,
            backgroundColor: 'rgba(37, 99, 235, 0.75)',
            borderColor: 'rgba(37, 99, 235, 1)',
            borderWidth: 1.5,
            borderRadius: 12,
            maxBarThickness: 34
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: {
              beginAtZero: true,
              grid: {
                color: 'rgba(0, 0, 0, 0.04)'
              },
              ticks: {
                precision: 0,
                font: { size: 11, weight: '500' }
              }
            },
            x: {
              grid: {
                display: false
              },
              ticks: {
                display: false
              }
            }
          },
          plugins: {
            legend: { display: false }
          }
        }
      });
    });
  </script>

  <!-- Detailed Listing Management Section -->
  <div class="glass-card rounded-3xl shadow-sm overflow-hidden mb-12">
    <div class="px-6 py-5 bg-gradient-to-r from-gray-50 via-white to-gray-50 border-b border-gray-100 flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h3 class="text-lg font-bold text-gray-900 tracking-tight">Your Listings Overview</h3>
        <p class="text-xs text-gray-500 font-normal">A detailed evaluation and shortcut management for all your properties.</p>
      </div>
      <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-semibold text-gray-600 shadow-sm">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> Accurate Status
      </span>
    </div>

    <% if (userListings && userListings.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-50/50 text-xs font-bold uppercase tracking-wider text-gray-500 border-b border-gray-100 select-none">
              <th class="px-6 py-4">Title & Location</th>
              <th class="px-6 py-4">Total Reviews</th>
              <th class="px-6 py-4">Rating</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100/60 text-sm">
            <% userListings.forEach(listing => { %>
              <tr class="hover:bg-white/40 transition duration-200">
                <td class="px-6 py-4">
                  <div class="flex items-center gap-4">
                    <div class="w-16 h-12 rounded-xl overflow-hidden flex-shrink-0 border border-gray-200/60 shadow-sm">
                      <img src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80' %>" 
                        alt="<%= listing.title %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                    </div>
                    <div>
                      <a href="/listings/<%= listing._id %>" class="font-bold text-gray-900 hover:text-airbnb transition tracking-wide text-sm leading-snug">
                        <%= listing.title %>
                      </a>
                      <p class="text-xs text-gray-400 mt-1 font-medium tracking-normal flex items-center gap-1">
                        <i class="fa-solid fa-location-dot text-rose-400 text-[10px]"></i> <%= listing.location %>, <%= listing.country %>
                      </p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 text-gray-600">
                  <span class="font-bold text-gray-800 text-sm"><%= listing.reviews.length %></span> <span class="text-xs text-gray-500">reviews</span>
                </td>
                <td class="px-6 py-4">
                  <div class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-amber-50 border border-amber-100 text-amber-600 font-bold text-xs select-none">
                    <i class="fa-solid fa-star text-[10px]"></i>
                    <% 
                      let totalRev = listing.reviews.length;
                      let sum = 0;
                      listing.reviews.forEach(r => { sum += r.rating; });
                      let listingAvg = totalRev > 0 ? (sum / totalRev).toFixed(1) : 'N/A';
                    %>
                    <span class="text-gray-800 font-bold tracking-tight"><%= listingAvg %></span>
                  </div>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-3 select-none">
                    <a href="/listings/<%= listing._id %>" class="inline-flex items-center gap-1 text-gray-600 hover:text-airbnb font-bold text-xs underline decoration-dotted hover:no-underline transition duration-200">
                      View
                    </a>
                    <a href="/listings/<%= listing._id %>/edit" class="inline-flex items-center gap-1 text-gray-600 hover:text-airbnb font-bold text-xs underline decoration-dotted hover:no-underline transition duration-200">
                      Edit
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="flex flex-col items-center justify-center p-12 text-center select-none">
        <div class="w-16 h-16 bg-gray-100 border border-gray-200/60 rounded-3xl flex items-center justify-center text-gray-400 mb-4 shadow-sm">
          <i class="fa-solid fa-house text-2xl text-gray-400"></i>
        </div>
        <h4 class="text-lg font-extrabold text-gray-900 tracking-tight">No properties found</h4>
        <p class="text-sm text-gray-500 mt-1 max-w-[280px] font-light leading-relaxed">You haven't added any listings yet. Start listing your home now!</p>
        <a href="/listings/new" class="mt-5 bg-gradient-to-r from-rose-500 to-airbnb hover:from-rose-600 hover:to-rose-700 text-white font-bold tracking-wide text-xs px-5 py-3 rounded-xl transition hover:shadow-lg">
          Create first listing
        </a>
      </div>
    <% } %>
    </div>
  </div>
</div>
