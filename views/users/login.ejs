<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/validation.css">

<div class="max-w-[1000px] mx-auto py-12 px-4 sm:px-6 lg:px-8 flex items-center justify-center min-h-[80vh]">
    <div class="flex flex-col lg:flex-row-reverse bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100 w-full">
        
        <!-- Right Banner -->
        <div class="lg:w-1/2 relative bg-gradient-to-bl from-airbnb to-rose-500 p-10 md:p-12 flex flex-col justify-between text-white overflow-hidden">
            <div class="relative z-10 h-full flex flex-col justify-center">
                <i class="fa-brands fa-airbnb text-5xl mb-6"></i>
                <h2 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">Welcome back to NullStay</h2>
                <p class="text-lg opacity-90 leading-relaxed">
                    Log in to manage your listings, view upcoming trips, and respond to your messages.
                </p>
            </div>

            <!-- Decorative background elements -->
            <div class="absolute -top-20 -right-20 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-20 -left-20 w-48 h-48 bg-black/10 rounded-full blur-2xl"></div>
        </div>

        <!-- Left Form Section -->
        <div class="lg:w-1/2 p-10 md:p-14 bg-white flex flex-col justify-center relative">
            <div class="mb-8">
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Log in</h3>
                <p class="text-gray-500">Welcome back! Please enter your details.</p>
            </div>

            <form action="/login" method="POST" class="space-y-6 needs-validation" novalidate>
                
                <!-- Username Field -->
                <div>
                    <label for="username" class="block text-sm font-semibold text-gray-800 mb-2">Username</label>
                    <div class="relative">
                        <div class="absolute top-0 left-0 h-[50px] pl-4 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-regular fa-user"></i>
                        </div>
                        <input type="text" id="username" name="username" required
                            class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-airbnb/50 focus:border-airbnb focus:bg-white transition-all shadow-sm"
                            placeholder="johndoe123">
                        <div class="valid-feedback text-sm text-green-600 mt-1.5">Looks good!</div>
                        <div class="invalid-feedback text-sm text-red-500 mt-1.5">Please enter your username.</div>
                    </div>
                </div>

                <!-- Password Field -->
                <div>
                    <label for="password" class="block text-sm font-semibold text-gray-800 mb-2">Password</label>
                    <div class="relative">
                        <div class="absolute top-0 left-0 h-[50px] pl-4 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-lock"></i>
                        </div>
                        <input type="password" id="password" name="password" required
                            class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 focus:outline-none focus:ring-2 focus:ring-airbnb/50 focus:border-airbnb focus:bg-white transition-all shadow-sm"
                            placeholder="••••••••">
                        <div class="valid-feedback text-sm text-green-600 mt-1.5">Looks good!</div>
                        <div class="invalid-feedback text-sm text-red-500 mt-1.5">Please enter your password.</div>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit"
                    class="w-full bg-airbnb hover:bg-rose-600 text-white font-semibold py-3.5 px-4 rounded-xl transition duration-300 shadow-lg shadow-airbnb/30 mt-4 flex items-center justify-center gap-2 group">
                    <span>Log in</span>
                    <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
                </button>
            </form>

            <div class="mt-8 text-center text-sm text-gray-600">
                Don't have an account? 
                <a href="/signup" class="font-semibold text-airbnb hover:underline transition">Sign up here</a>
            </div>
        </div>
    </div>
</div>
