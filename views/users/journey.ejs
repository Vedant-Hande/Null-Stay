<% layout('layouts/boilerplate') -%>

<div class="max-w-5xl mx-auto py-12 px-4">
    <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 tracking-tight">Your Travel Lineage</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Explore the legacy of your journeys. See where you've been and discover where your wanderlust might take you next.</p>
    </div>

    <div class="relative">
        <!-- Vertical Line (The Trunk) -->
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-[75%] bg-gray-200 z-0"></div>

        <!-- Node 1 (Past Trip) -->
        <div class="relative z-10 flex items-center justify-between w-full mb-16">
            <div class="w-5/12 text-right pr-4 md:pr-8">
                <div class="inline-block bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 w-full max-w-sm ml-auto cursor-pointer group">
                    <div class="h-48 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                    </div>
                    <div class="p-5 text-left">
                        <p class="text-xs text-airbnb font-bold uppercase tracking-wider mb-1">Dec 2024</p>
                        <h3 class="text-xl font-bold text-gray-900 mb-1">Skyline Penthouse</h3>
                        <p class="text-gray-500 text-sm">New York, USA</p>
                    </div>
                </div>
            </div>
            <div class="w-2/12 flex justify-center">
                <div class="w-6 h-6 md:w-8 md:h-8 rounded-full bg-airbnb border-4 border-white shadow-md z-10"></div>
            </div>
            <div class="w-5/12 pl-4 md:pl-8"></div>
        </div>

        <!-- Node 2 (Past Trip) -->
        <div class="relative z-10 flex items-center justify-between w-full mb-16 flex-row-reverse">
            <div class="w-5/12 pl-4 md:pl-8 text-left">
                <div class="inline-block bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 w-full max-w-sm cursor-pointer group">
                    <div class="h-48 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                    </div>
                    <div class="p-5 text-left">
                        <p class="text-xs text-airbnb font-bold uppercase tracking-wider mb-1">Feb 2025</p>
                        <h3 class="text-xl font-bold text-gray-900 mb-1">Oceanfront Villa</h3>
                        <p class="text-gray-500 text-sm">Malibu, California</p>
                    </div>
                </div>
            </div>
            <div class="w-2/12 flex justify-center">
                <div class="w-6 h-6 md:w-8 md:h-8 rounded-full bg-airbnb border-4 border-white shadow-md z-10"></div>
            </div>
            <div class="w-5/12 pr-4 md:pr-8"></div>
        </div>

        <!-- Node 3 (Past Trip) -->
        <div class="relative z-10 flex items-center justify-between w-full mb-12">
            <div class="w-5/12 text-right pr-4 md:pr-8">
                <div class="inline-block bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 w-full max-w-sm ml-auto cursor-pointer group">
                    <div class="h-48 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                    </div>
                    <div class="p-5 text-left">
                        <p class="text-xs text-airbnb font-bold uppercase tracking-wider mb-1">April 2026</p>
                        <h3 class="text-xl font-bold text-gray-900 mb-1">Alpine Cabin</h3>
                        <p class="text-gray-500 text-sm">Swiss Alps</p>
                    </div>
                </div>
            </div>
            <div class="w-2/12 flex justify-center">
                <div class="w-6 h-6 md:w-8 md:h-8 rounded-full bg-airbnb border-4 border-white shadow-md z-10"></div>
            </div>
            <div class="w-5/12 pl-4 md:pl-8"></div>
        </div>

        <div class="text-center mt-16 mb-12 relative z-10">
            <div class="flex items-center justify-center gap-4 mb-8">
                <div class="h-px bg-gray-300 flex-grow max-w-[100px]"></div>
                <span class="bg-gradient-to-r from-rose-100 to-rose-50 text-airbnb font-semibold py-2 px-6 rounded-full border border-rose-200 shadow-sm inline-flex items-center gap-2">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> AI Suggested Next Chapters
                </span>
                <div class="h-px bg-gray-300 flex-grow max-w-[100px]"></div>
            </div>
        </div>

        <!-- Suggested Destinations Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10 max-w-4xl mx-auto">
            
            <!-- Suggestion 1 -->
            <div class="bg-white rounded-2xl shadow-xl border border-rose-100 overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 group cursor-pointer flex flex-col">
                <div class="relative h-56 overflow-hidden">
                    <div class="absolute top-4 left-4 z-20 bg-black/60 text-white text-xs px-3 py-1.5 rounded-full backdrop-blur-sm border border-white/20 font-medium tracking-wide">Contrast Trip</div>
                    <img src="https://images.unsplash.com/photo-1540541338287-41700207dee6?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover group-hover:scale-110 transition duration-700 opacity-95">
                </div>
                <div class="p-6 flex flex-col flex-grow">
                    <h3 class="text-2xl font-bold text-gray-900 mb-2">Tropical Estate</h3>
                    <p class="text-gray-600 mb-6 flex-grow">Escape the cold. You loved the ocean in Malibu, how about an upgraded tropical retreat in Bali?</p>
                    <button class="w-full bg-gray-900 hover:bg-black text-white font-semibold py-3 rounded-xl transition duration-300">Explore Retreat</button>
                </div>
            </div>

            <!-- Suggestion 2 -->
            <div class="bg-white rounded-2xl shadow-xl border border-blue-100 overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 group cursor-pointer flex flex-col">
                <div class="relative h-56 overflow-hidden">
                    <div class="absolute top-4 left-4 z-20 bg-black/60 text-white text-xs px-3 py-1.5 rounded-full backdrop-blur-sm border border-white/20 font-medium tracking-wide">Proximity Trip</div>
                    <img src="https://images.unsplash.com/photo-1499856871958-5b9627545d1a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover group-hover:scale-110 transition duration-700 opacity-95">
                </div>
                <div class="p-6 flex flex-col flex-grow">
                    <h3 class="text-2xl font-bold text-gray-900 mb-2">Parisian Loft</h3>
                    <p class="text-gray-600 mb-6 flex-grow">Keep exploring Europe. After the Swiss Alps, experience the elegance of central Paris.</p>
                    <button class="w-full bg-gray-900 hover:bg-black text-white font-semibold py-3 rounded-xl transition duration-300">Explore Loft</button>
                </div>
            </div>

        </div>
    </div>
</div>
