<% layout("/layouts/boilerplate") %>
<!-- Include Inter Google Font & custom styles -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/userDashboard.css">


<div class="max-w-[1240px] mx-auto pb-16 pt-8 px-4 md:px-0 select-none">
  <!-- Top Header section with clean minimalist format -->
  <div class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
      <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-rose-50 border border-rose-100 rounded-full text-xs font-semibold text-airbnb mb-2 shadow-sm select-none">
        <span class="w-1.5 h-1.5 rounded-full bg-airbnb animate-pulse"></span> Profile & Account
      </span>
      <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Your Account Settings</h1>
      <p class="text-sm text-gray-500 font-light mt-1">Manage your user profile details, listings, and analytics in one place.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    <!-- Left Navigation Sidebar -->
    <%- include("../includes/userSidebar.ejs", { activeTab: "personal" }) %>

    <!-- Right Content Area -->
    <div class="md:col-span-8 lg:col-span-9">
      <div class="glass-card rounded-3xl p-6 md:p-8 shadow-sm flex flex-col gap-8">
        
        <!-- User Welcome / Avatar Row -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 pb-6 border-b border-gray-100">
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 rounded-3xl bg-gradient-to-tr from-rose-50 to-rose-100 border border-rose-200 text-airbnb flex items-center justify-center font-extrabold text-2xl tracking-wide uppercase select-none shadow-sm">
              <%= user.username.charAt(0) %>
            </div>
            <div>
              <h2 class="text-xl font-bold text-gray-900 tracking-tight leading-snug">Welcome, <%= user.username %>!</h2>
              <p class="text-xs text-gray-400 mt-1 font-medium select-none">Host & Guest since <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></p>
            </div>
          </div>
          <a href="/logout" class="inline-flex items-center justify-center bg-gray-50 border border-gray-200 text-gray-600 hover:bg-gray-100 font-bold tracking-wide text-xs px-4 py-2.5 rounded-xl transition duration-200">
            Log out
          </a>
        </div>

        <!-- Personal Info Form -->
        <form action="/user/account?_method=PUT" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6 select-none">
          <div>
            <label for="username" class="text-xs font-bold uppercase tracking-wider text-gray-400 select-none block mb-1">Username</label>
            <input type="text" id="username" name="username" value="<%= user.username %>" required
              class="w-full text-sm text-gray-800 bg-white border border-gray-200 focus:outline-none focus:border-airbnb focus:ring-2 focus:ring-rose-50 px-4 py-3 rounded-xl font-medium shadow-sm transition">
          </div>
          <div>
            <label for="email" class="text-xs font-bold uppercase tracking-wider text-gray-400 select-none block mb-1">Email address</label>
            <input type="email" id="email" name="email" value="<%= user.email %>" required
              class="w-full text-sm text-gray-800 bg-white border border-gray-200 focus:outline-none focus:border-airbnb focus:ring-2 focus:ring-rose-50 px-4 py-3 rounded-xl font-medium shadow-sm transition">
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-wider text-gray-400 select-none block mb-1">Date Created</label>
            <div class="text-sm text-gray-800 bg-gray-50 border border-gray-100 px-4 py-3 rounded-xl font-medium shadow-sm">
              <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
            </div>
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-wider text-gray-400 select-none block mb-1">Account Type</label>
            <div class="text-sm text-gray-800 bg-gray-50 border border-gray-100 px-4 py-3 rounded-xl font-medium shadow-sm">
              Standard Member
            </div>
          </div>
          <div class="md:col-span-2 pt-2 flex justify-end">
            <button type="submit" class="bg-airbnb hover:bg-rose-600 text-white font-bold tracking-wide text-xs px-6 py-3 rounded-xl shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition duration-200">
              Save Changes
            </button>
          </div>
        </form>

        <!-- Account Activity Stats / Summaries -->
        <div class="pt-6 border-t border-gray-100 flex flex-col gap-4 select-none">
          <h3 class="text-base font-bold text-gray-900 tracking-tight">Your Activity Overview</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-4 rounded-2xl bg-gray-50 border border-gray-100 flex items-center gap-4 shadow-sm">
              <div class="w-10 h-10 bg-rose-50 border border-rose-100 text-airbnb rounded-xl flex items-center justify-center font-bold">
                <i class="fa-solid fa-house"></i>
              </div>
              <div>
                <h4 class="text-base font-bold text-gray-900 leading-snug"><%= listingsCount %></h4>
                <p class="text-xs text-gray-400 font-medium">Owned Listings</p>
              </div>
            </div>

            <div class="p-4 rounded-2xl bg-gray-50 border border-gray-100 flex items-center gap-4 shadow-sm">
              <div class="w-10 h-10 bg-blue-50 border border-blue-100 text-blue-600 rounded-xl flex items-center justify-center font-bold">
                <i class="fa-solid fa-comments"></i>
              </div>
              <div>
                <h4 class="text-base font-bold text-gray-900 leading-snug"><%= reviewsCount %></h4>
                <p class="text-xs text-gray-400 font-medium">Reviews Authored</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Scrollable Listings Overview -->
        <div class="pt-6 border-t border-gray-100 flex flex-col gap-4 select-none">
          <div class="flex items-center justify-between">
            <h3 class="text-base font-bold text-gray-900 tracking-tight">Your Properties</h3>
            <span class="text-xs font-semibold text-gray-400"><%= userListings.length %> listings</span>
          </div>
          <% if (userListings && userListings.length > 0) { %>
            <div class="max-h-[220px] overflow-y-auto pr-1 flex flex-col gap-3 rounded-2xl custom-scroll">
              <% userListings.forEach(listing => { %>
                <div class="p-3 bg-gray-50 border border-gray-100 rounded-xl flex items-center justify-between gap-4 shadow-sm hover:border-gray-200 transition duration-200">
                  <div class="flex items-center gap-3">
                    <div class="w-14 h-14 bg-gray-200 rounded-xl overflow-hidden flex-shrink-0">
                      <% if (listing.image && listing.image.url) { %>
                        <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="w-full h-full object-cover">
                      <% } else { %>
                        <div class="w-full h-full bg-gray-300 flex items-center justify-center text-white"><i class="fa-solid fa-image"></i></div>
                      <% } %>
                    </div>
                    <div>
                      <h4 class="text-sm font-bold text-gray-800 leading-snug"><%= listing.title %></h4>
                      <p class="text-xs text-gray-400 mt-0.5 font-medium"><%= listing.location %>, <%= listing.country %></p>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 select-none">
                    <a href="/listings/<%= listing._id %>" class="text-xs font-bold text-gray-700 hover:text-airbnb px-3 py-1.5 rounded-lg bg-white border border-gray-100 hover:border-rose-100 transition duration-200">
                      View
                    </a>
                    <a href="/listings/<%= listing._id %>/edit" class="text-xs font-bold text-gray-700 hover:text-airbnb px-3 py-1.5 rounded-lg bg-white border border-gray-100 hover:border-rose-100 transition duration-200">
                      Edit
                    </a>
                    <form id="deleteForm-<%= listing._id %>" action="/listings/<%= listing._id %>/delete?_method=DELETE" method="POST">
                      <button type="button" onclick="openDeleteModal(event, document.getElementById('deleteForm-<%= listing._id %>'))" class="text-xs font-bold text-rose-600 hover:text-rose-700 px-3 py-1.5 rounded-lg bg-white border border-gray-100 hover:border-rose-100 transition duration-200">
                        Delete
                      </button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="p-6 border border-dashed border-gray-200 rounded-2xl flex flex-col items-center justify-center text-center">
              <div class="w-10 h-10 bg-gray-50 text-gray-400 rounded-full flex items-center justify-center mb-2"><i class="fa-solid fa-house"></i></div>
              <p class="text-sm text-gray-500 font-medium">No listings found</p>
              <a href="/listings/new" class="text-xs font-bold text-airbnb hover:underline mt-1">Create your first listing</a>
            </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>
</div>
