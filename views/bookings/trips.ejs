<% layout("/layouts/boilerplate") %>
<%- include('../includes/booking/pageShellStart.ejs') %>

<div class="u-flex u-flex-col md:flex-row md:items-end u-justify-between gap-medium margin-bottom-xl">
  <div>
    <p class="booking-kicker margin-bottom-small">Travel</p>
    <h1 class="text-3xl font-semibold tracking-tight text-gray-900">Your trips</h1>
    <p class="text-gray-500 margin-top-xs">Upcoming getaways and past stays</p>
  </div>
  <a href="/listings"
    class="u-inline-block padding-x-large padding-y-small bg-gray-900 text-white text-sm font-bold rounded-xl hover:bg-black transition">
    <i class="fa-solid fa-magnifying-glass"></i> Explore stays
  </a>
</div>

<div class="u-flex u-flex-wrap gap-small margin-bottom-xl">
  <% const tabs = [
    { id: 'all', label: 'All', count: counts.all },
    { id: 'upcoming', label: 'Upcoming', count: counts.upcoming },
    { id: 'past', label: 'Past', count: counts.past },
    { id: 'cancelled', label: 'Cancelled', count: counts.cancelled },
  ]; %>
  <% tabs.forEach(tab => { %>
    <a href="/bookings/trips?filter=<%= tab.id %>"
      class="booking-tab padding-y-small padding-x-medium <%= filter === tab.id ? 'booking-tab--active' : '' %>">
      <%= tab.label %>
      <span class="opacity-70 margin-left-xs">(<%= tab.count %>)</span>
    </a>
  <% }) %>
</div>

<% if (!trips.length) { %>
  <div class="booking-glass padding-3xl u-text-center">
    <p class="booking-kicker u-text-center margin-bottom-small">No trips</p>
    <h2 class="text-xl font-bold text-gray-900 margin-bottom-small">No trips here yet</h2>
    <p class="text-gray-500 margin-bottom-xl max-w-sm mx-auto">
      <% if (filter === 'all') { %>
        When you book a stay, it will show up here.
      <% } else { %>
        Try another filter or book your next adventure.
      <% } %>
    </p>
    <a href="/listings" class="u-inline-block padding-x-xl padding-y-medium bg-airbnb text-white font-bold rounded-xl hover:bg-rose-600 transition shadow-lg">
      Start exploring
    </a>
  </div>
<% } else { %>
  <div class="u-grid gap-large">
    <% trips.forEach((trip) => { %>
      <% const listing = trip.listing; %>
      <% if (listing) { %>
      <article class="booking-trip-card booking-glass overflow-hidden u-flex u-flex-col md:flex-row">
        <a href="/listings/<%= listing._id %>" class="md:w-56 lg:w-64 shrink-0 relative block group">
          <% if (listing.image?.url) { %>
            <img src="<%= listing.image.url %>" alt="" class="w-full h-48 md:h-full min-h-[12rem] object-cover group-hover:scale-[1.02] transition duration-500" />
          <% } else { %>
            <div class="w-full h-48 md:h-full min-h-[12rem] bg-gray-100 u-flex u-items-center u-justify-center">
              <i class="fa-solid fa-image text-3xl text-gray-300"></i>
            </div>
          <% } %>
        </a>
        <div class="padding-large u-flex-1 u-flex u-flex-col gap-medium">
          <div class="u-flex u-justify-between u-items-start gap-medium u-flex-wrap">
            <div>
              <a href="/listings/<%= listing._id %>" class="text-xl font-bold text-gray-900 hover:underline leading-tight">
                <%= listing.title %>
              </a>
              <p class="text-sm text-gray-500 margin-top-xs"><%= listing.location %>, <%= listing.country %></p>
            </div>
            <%- include('../includes/booking/statusBadge.ejs', { status: trip.status }) %>
          </div>

          <div class="u-flex u-flex-wrap gap-medium text-sm text-gray-700">
            <span class="u-inline-block gap-small">
              <i class="fa-regular fa-calendar text-gray-400"></i>
              <%= bookingDisplay.bookingDateRange(trip.checkIn, trip.checkOut) %>
            </span>
            <span class="u-inline-block gap-small">
              <i class="fa-solid fa-user-group text-gray-400"></i>
              <%= trip.guests %> guest<%= trip.guests > 1 ? 's' : '' %>
            </span>
            <span class="u-inline-block gap-small">
              <i class="fa-solid fa-moon text-gray-400"></i>
              <%= trip.nights %> nights
            </span>
          </div>

          <div class="u-flex u-items-end u-justify-between gap-medium u-flex-wrap mt-auto padding-top-small border-t border-gray-100">
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">Total paid</p>
              <p class="text-lg font-bold text-gray-900"><%= bookingDisplay.formatInr(trip.total) %></p>
              <% if (trip.confirmationCode) { %>
                <p class="text-xs text-gray-500 margin-top-xs font-mono">Ref <%= trip.confirmationCode %></p>
              <% } %>
            </div>
            <div class="u-flex gap-medium u-flex-wrap">
              <a href="/bookings/<%= trip._id %>"
                class="padding-x-medium padding-y-small bg-gray-900 text-white text-sm font-bold rounded-xl hover:bg-black transition">
                View details
              </a>
              <% if (trip.status === 'confirmed' || trip.status === 'pending') { %>
                <form action="/bookings/<%= trip._id %>/cancel" method="POST"
                  data-confirm="Cancel this reservation? This cannot be undone."
                  data-confirm-title="Cancel trip"
                  data-confirm-ok="Yes, cancel"
                  data-confirm-danger="true">
                  <button type="submit"
                    class="padding-x-medium padding-y-small border border-gray-200 text-sm font-bold rounded-xl hover:bg-gray-50 text-rose-600 transition">
                    Cancel
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      </article>
      <% } %>
    <% }) %>
  </div>
<% } %>

<%- include('../includes/booking/pageShellEnd.ejs') %>

