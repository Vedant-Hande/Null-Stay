<% layout('layouts/landing') -%>

<div class="ns-static">
  <header class="ns-static-hero">
    <div class="ns-static-hero__glow" aria-hidden="true"></div>
    <div class="ns-static-hero__inner">
      <div class="ns-status-hero-badge">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        All systems operational
      </div>
      <h1>System <em>status</em></h1>
      <p class="ns-static-hero__sub">Live health of the NullStay app — uptime, memory, database, and environment.</p>
    </div>
  </header>

  <div class="ns-static-chips">
    <span class="ns-static-chip"><i class="fa-solid fa-server"></i> Node <%= stats.nodeVersion %></span>
    <span class="ns-static-chip"><i class="fa-solid fa-database"></i> <%= stats.dbStatus %></span>
    <span class="ns-static-chip"><i class="fa-solid fa-clock"></i> Up <%= stats.appUptime %></span>
  </div>

  <div class="ns-status-grid">
    <article class="ns-status-card">
      <div class="ns-status-card__icon"><i class="fa-solid fa-clock"></i></div>
      <h3>Uptime</h3>
      <p class="ns-status-card__label">Process running time</p>
      <div class="ns-status-card__value"><%= stats.appUptime %></div>
      <div class="ns-status-card__footer">
        <span>PID</span>
        <span><%= stats.pid %></span>
      </div>
    </article>

    <article class="ns-status-card">
      <div class="ns-status-card__icon"><i class="fa-solid fa-memory"></i></div>
      <h3>Memory</h3>
      <p class="ns-status-card__label">V8 heap used / total</p>
      <div class="ns-status-card__value" style="font-size: 1.25rem;"><%= stats.heapUsed %></div>
      <div class="ns-status-card__footer">
        <span>Utilization</span>
        <span><%= stats.heapPercent %>%</span>
      </div>
    </article>

    <article class="ns-status-card">
      <div class="ns-status-card__icon"><i class="fa-solid fa-database"></i></div>
      <h3>Database</h3>
      <p class="ns-status-card__label">MongoDB</p>
      <div class="ns-status-card__value" style="font-size: 1.2rem; color: <%= stats.dbStatus === 'Connected' ? '#059669' : '#d97706' %>"><%= stats.dbStatus %></div>
      <div class="ns-status-card__footer">
        <span>Listings</span>
        <span><%= stats.listingsCount %></span>
      </div>
    </article>

    <article class="ns-status-card">
      <div class="ns-status-card__icon"><i class="fa-solid fa-gauge-high"></i></div>
      <h3>Resources</h3>
      <p class="ns-status-card__label">Active handles / requests</p>
      <div class="ns-status-card__value" style="font-size: 1.125rem;"><%= stats.activeHandles %> / <%= stats.activeRequests %></div>
      <div class="ns-status-card__footer">
        <span>Load</span>
        <span><%= stats.loadAvg %></span>
      </div>
    </article>

    <article class="ns-status-card">
      <div class="ns-status-card__icon"><i class="fa-solid fa-star"></i></div>
      <h3>Content</h3>
      <p class="ns-status-card__label">Platform data</p>
      <div class="ns-status-card__value" style="font-size: 1.125rem;"><%= stats.reviewsCount %> reviews</div>
      <div class="ns-status-card__footer">
        <span>Collections</span>
        <span><%= stats.collectionsCount %></span>
      </div>
    </article>

    <article class="ns-status-card ns-status-card--wide">
      <div class="ns-status-card__icon"><i class="fa-solid fa-sliders"></i></div>
      <h3>Environment</h3>
      <p class="ns-status-card__label">Runtime configuration</p>
      <div style="margin-top: 1rem;">
        <div class="ns-status-env-row"><span>Environment</span><strong><%= stats.env %></strong></div>
        <div class="ns-status-env-row"><span>Node version</span><strong><%= stats.nodeVersion %></strong></div>
        <div class="ns-status-env-row"><span>Port</span><strong><%= stats.port %></strong></div>
        <div class="ns-status-env-row"><span>RSS memory</span><strong><%= stats.rss %></strong></div>
        <div class="ns-status-env-row"><span>Server time</span><strong><%= stats.serverTime %></strong></div>
      </div>
      <button type="button" class="ns-status-refresh" onclick="window.location.reload()">
        <i class="fa-solid fa-arrows-rotate"></i> Refresh metrics
      </button>
    </article>
  </div>
</div>
