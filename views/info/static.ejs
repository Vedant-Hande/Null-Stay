<% layout('layouts/boilerplate') -%>

<div class="max-w-4xl mx-auto py-16 px-4">
    <div class="mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4"><%= title %></h1>
        <p class="text-lg text-gray-500 font-light">Last updated: April 2026</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed space-y-8">
        <section>
            <h2 class="text-2xl font-semibold text-gray-900 mb-4">1. Welcome to NullStay</h2>
            <p>
                At NullStay, we are committed to providing a premium marketplace for luxury vacation rentals and unique homes. 
                Whether you are a guest looking for your next adventure or a host sharing your home, our platform is built 
                on trust, transparency, and high-quality service.
            </p>
        </section>

        <section>
            <h2 class="text-2xl font-semibold text-gray-900 mb-4">2. Our Mission</h2>
            <p>
                Our mission is to create a world where anyone can belong anywhere, by providing a high-fidelity 
                and reliable experience that connects people across the globe.
            </p>
        </section>

        <section>
            <h2 class="text-2xl font-semibold text-gray-900 mb-4">3. Getting Started</h2>
            <p>
                You can browse thousands of unique stays, from beachfront villas to historic castles. 
                Use our search filters to find exactly what you're looking for, and book with confidence 
                knowing that every listing is curated for excellence.
            </p>
        </section>

        <section class="bg-gray-50 p-8 rounded-2xl border border-gray-100">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Need help?</h3>
            <p class="text-gray-600 mb-6">Our support team is available 24/7 to assist you with any questions or concerns.</p>
            <a href="mailto:support@nullstay.com" class="inline-block bg-gray-900 text-white font-bold py-3 px-8 rounded-xl hover:bg-black transition shadow-md">
                Contact Support
            </a>
        </section>
    </div>
</div>
