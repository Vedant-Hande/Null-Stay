<% layout('layouts/boilerplate') -%>

<div class="bg-gray-50 -mt-8 pt-16 pb-24">
    <!-- Help Center Hero -->
    <div class="max-w-4xl mx-auto px-6 text-center mb-16">
        <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-8 tracking-tight">Help Centre</h1>
        
        <!-- Search Bar -->
        <div class="relative max-w-2xl mx-auto group">
            <i class="fa-solid fa-magnifying-glass absolute left-6 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-airbnb transition-colors"></i>
            <input type="text" placeholder="Search for help topics..." 
                class="w-full py-5 pl-14 pr-6 bg-white border border-gray-200 rounded-full shadow-lg focus:outline-none focus:ring-2 focus:ring-airbnb/20 focus:border-airbnb transition-all text-lg">
        </div>
    </div>

    <!-- Category Grid -->
    <div class="max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Getting Started -->
            <div class="bg-white p-8 rounded-3xl border border-gray-100 hover:shadow-xl transition-all duration-300 group cursor-pointer">
                <div class="w-12 h-12 bg-blue-50 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-rocket text-xl text-blue-500"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Getting Started</h3>
                <p class="text-gray-500 mb-6 font-light">Learn the basics of booking, hosting, and managing your account.</p>
                <a href="#" class="text-airbnb font-semibold hover:underline flex items-center gap-2">
                    Browse topics <i class="fa-solid fa-chevron-right text-xs"></i>
                </a>
            </div>

            <!-- Your Bookings -->
            <div class="bg-white p-8 rounded-3xl border border-gray-100 hover:shadow-xl transition-all duration-300 group cursor-pointer">
                <div class="w-12 h-12 bg-rose-50 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-calendar-check text-xl text-airbnb"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Your Bookings</h3>
                <p class="text-gray-500 mb-6 font-light">Manage reservations, cancellations, and house rules.</p>
                <a href="#" class="text-airbnb font-semibold hover:underline flex items-center gap-2">
                    Browse topics <i class="fa-solid fa-chevron-right text-xs"></i>
                </a>
            </div>

            <!-- Trust & Safety -->
            <div class="bg-white p-8 rounded-3xl border border-gray-100 hover:shadow-xl transition-all duration-300 group cursor-pointer">
                <div class="w-12 h-12 bg-green-50 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-shield-halved text-xl text-green-500"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Trust & Safety</h3>
                <p class="text-gray-500 mb-6 font-light">Learn about our protection for hosts and guests.</p>
                <a href="#" class="text-airbnb font-semibold hover:underline flex items-center gap-2">
                    Browse topics <i class="fa-solid fa-chevron-right text-xs"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Contact Support Banner -->
    <div class="max-w-4xl mx-auto px-6 mt-24">
        <div class="bg-gray-900 rounded-[2rem] p-12 flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-airbnb/20 rounded-full blur-3xl -mr-32 -mt-32"></div>
            <div class="relative z-10">
                <h2 class="text-3xl font-bold text-white mb-4">Still need help?</h2>
                <p class="text-gray-400 text-lg font-light">Our support team is available 24/7 to assist you.</p>
            </div>
            <a href="mailto:support@nullstay.com" class="relative z-10 bg-white text-gray-900 font-bold py-4 px-10 rounded-2xl hover:bg-gray-100 transition shadow-lg transform hover:-translate-y-1">
                Contact Support
            </a>
        </div>
    </div>
</div>
