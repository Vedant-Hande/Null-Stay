<% layout('layouts/boilerplate') -%>

<!-- Override Boilerplate Spacing for Full Bleed Effect -->
<style>
    main.flex-grow {
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }
</style>

<!-- Hero Section: Full viewport height minus navbar -->
<div class="relative w-full h-[85vh] overflow-hidden bg-neutral-900 group">
    <!-- Image -->
    <img src="/images/hero_villa.png" alt="Luxury Villa" class="absolute inset-0 w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-[15s] ease-out">
    
    <!-- Sophisticated Vignette & Gradient Overlays -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/80"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-transparent via-transparent to-black/40"></div>

    <!-- Centered Content -->
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4 z-10">
        <!-- Badge -->
        <div class="inline-block px-4 py-1.5 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white text-xs font-semibold uppercase tracking-[0.2em] mb-6 animate-fade-in-up">
            Introducing NullStay Premium
        </div>
        
        <h1 class="text-white text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tighter drop-shadow-2xl mb-8 leading-[1.1] max-w-5xl">
            Find your next <br class="hidden md:block"/> 
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-gray-200 to-gray-500">masterpiece</span>
        </h1>

        <!-- Premium Glassmorphism Search / CTA -->
        <div class="mt-4 p-2 bg-white/10 backdrop-blur-xl rounded-full border border-white/20 shadow-[0_32px_64px_-12px_rgba(0,0,0,0.5)] flex flex-row items-center justify-between w-full max-w-lg md:max-w-2xl transform transition hover:bg-white/20 hover:scale-[1.02] duration-500">
            <div class="flex-1 flex flex-row items-center divide-x divide-white/20 text-left">
                <div class="flex-1 px-6 py-2">
                    <p class="text-xs text-gray-300 font-semibold uppercase tracking-wider mb-1">Location</p>
                    <p class="text-white font-medium truncate">Where are you going?</p>
                </div>
                <div class="flex-1 px-6 py-2 hidden sm:block">
                    <p class="text-xs text-gray-300 font-semibold uppercase tracking-wider mb-1">Dates</p>
                    <p class="text-white font-medium">Any week</p>
                </div>
            </div>
            <a href="/listings" class="bg-airbnb hover:bg-rose-600 text-white rounded-full h-14 w-14 md:h-16 md:w-auto md:px-8 flex items-center justify-center gap-2 transition-all duration-300 shadow-lg shadow-airbnb/30 group-hover:shadow-airbnb/50">
                <i class="fa-solid fa-magnifying-glass"></i>
                <span class="hidden md:block font-bold">Search</span>
            </a>
        </div>
    </div>
</div>

<!-- Main Content Container with standard padding -->
<div class="max-w-[2520px] mx-auto xl:px-20 md:px-10 sm:px-2 px-4 py-16 md:py-24">
    
    <!-- Premium Curated Selection -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
        <div>
            <h2 class="text-4xl md:text-5xl font-bold text-neutral-900 tracking-tight mb-3">Curated Collections</h2>
            <p class="text-lg text-neutral-500 font-light">Handpicked properties for extraordinary experiences.</p>
        </div>
        <a href="/listings" class="group flex items-center gap-2 text-airbnb font-semibold hover:text-rose-600 transition-colors">
            Explore all <i class="fa-solid fa-arrow-right transform group-hover:translate-x-1 transition-transform"></i>
        </a>
    </div>

    <!-- Horizontal Scrollable Cards -->
    <div class="flex overflow-x-auto pb-10 -mx-4 px-4 sm:mx-0 sm:px-0 gap-6 sm:gap-8 snap-x hide-scrollbar">
        
        <!-- Collection 1 -->
        <a href="/listings" class="min-w-[85vw] sm:min-w-[400px] md:min-w-[450px] relative h-[500px] rounded-[2rem] overflow-hidden group snap-center cursor-pointer shadow-xl">
            <div class="absolute inset-0 bg-neutral-900">
                <img src="https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Coastal Homes" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700">
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
                <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-2">Collection</p>
                <h3 class="text-white text-3xl font-bold mb-2">Coastal Masterpieces</h3>
                <p class="text-gray-300 font-light opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500">Wake up to the sound of the ocean.</p>
            </div>
        </a>

        <!-- Collection 2 -->
        <a href="/listings" class="min-w-[85vw] sm:min-w-[400px] md:min-w-[450px] relative h-[500px] rounded-[2rem] overflow-hidden group snap-center cursor-pointer shadow-xl">
            <div class="absolute inset-0 bg-neutral-900">
                <img src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Mountain Cabins" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700">
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
                <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-2">Collection</p>
                <h3 class="text-white text-3xl font-bold mb-2">Secluded Cabins</h3>
                <p class="text-gray-300 font-light opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500">Disconnect in the heart of nature.</p>
            </div>
        </a>

        <!-- Collection 3 -->
        <a href="/listings" class="min-w-[85vw] sm:min-w-[400px] md:min-w-[450px] relative h-[500px] rounded-[2rem] overflow-hidden group snap-center cursor-pointer shadow-xl">
            <div class="absolute inset-0 bg-neutral-900">
                <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Modern Mansions" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700">
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
                <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-2">Collection</p>
                <h3 class="text-white text-3xl font-bold mb-2">Modern Mansions</h3>
                <p class="text-gray-300 font-light opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500">Unparalleled luxury and design.</p>
            </div>
        </a>
    </div>

    <!-- Become a Host - Luxury Edition -->
    <div class="mt-20 relative w-full rounded-[2.5rem] overflow-hidden shadow-2xl group flex items-center justify-between bg-neutral-900 p-10 md:p-20">
        <!-- Artistic Background Elements -->
        <div class="absolute -right-20 -top-20 w-[600px] h-[600px] bg-gradient-to-br from-airbnb/20 to-purple-600/20 rounded-full blur-[100px] group-hover:scale-110 transition-transform duration-1000"></div>
        <div class="absolute -left-20 -bottom-20 w-[400px] h-[400px] bg-gradient-to-tr from-rose-500/20 to-orange-500/20 rounded-full blur-[80px] group-hover:scale-110 transition-transform duration-1000"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center justify-between w-full gap-10">
            <div class="max-w-xl">
                <h2 class="text-4xl md:text-6xl font-bold text-white tracking-tight mb-6">Open your door<br/>to the world.</h2>
                <p class="text-xl text-gray-300 font-light mb-8">Earn extra income and unlock new opportunities by sharing your space.</p>
            </div>
            <a href="/listings/new" class="shrink-0 px-10 py-5 bg-white text-neutral-900 font-bold text-lg rounded-full shadow-[0_0_40px_rgba(255,255,255,0.3)] hover:shadow-[0_0_60px_rgba(255,255,255,0.5)] hover:scale-105 transition-all duration-300">
                Become a Host
            </a>
        </div>
    </div>
</div>

<style>
    /* Animation for the hero badge */
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
        animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    /* Hide scrollbar for collections */
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
